{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Specifies the location in which the Azure Managed Identity resource(s) should be deployed."
            },
            "type": "string"
        },
        "managedIdentityName": {
            "maxLength": 128,
            "metadata": {
                "description": "Specifies the name of the Azure Managed Identity."
            },
            "minLength": 3,
            "type": "string"
        },
        "tags": {
            "defaultValue": {},
            "metadata": {
                "description": "Specifies the set of tag key-value pairs that will be assigned to the Azure Managed Identity."
            },
            "type": "object"
        }
    },
    "variables": {
        "managedIdentityUserAssignedIdentitiesApiVersion": "2018-11-30"
    },
    "resources": [
        {
            "apiVersion": "[variables('managedIdentityUserAssignedIdentitiesApiVersion')]",
            "location": "[parameters('location')]",
            "name": "[parameters('managedIdentityName')]",
            "properties": {},
            "tags": "[parameters('tags')]",
            "type": "Microsoft.ManagedIdentity/userAssignedIdentities"
        }
    ],
    "outputs": {
        "principalId": {
            "type": "string",
            "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('managedIdentityName')), variables('managedIdentityUserAssignedIdentitiesApiVersion'), 'Full').properties.principalId]"
        }
    }
}
