{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "principalId": {
            "metadata": {
                "description": "Specifies the principal id that will be granted rights on an Azure resource."
            },
            "type": "string"
        },
        "principalType": {
            "defaultValue": "ServicePrincipal",
            "metadata": {
                "description": "Specifies the principal type."
            },
            "type": "string"
        },
        "roleDefinitionId": {
            "metadata": {
                "description": "Specifies the role definition id that will be assigned to the principal."
            },
            "type": "string"
        }
    },
    "variables": {
        "authorizationRoleAssignmentsApiVersion":"2018-09-01-preview"
    },
    "resources": [
        {
            "apiVersion": "[variables('authorizationRoleAssignmentsApiVersion')]",
            "name": "[guid(parameters('principalId'), parameters('roleDefinitionId'))]",
            "properties": {
                "canDelegate": false,
                "principalId": "[parameters('principalId')]",
                "principalType": "[parameters('principalType')]",
                "roleDefinitionId": "[parameters('roleDefinitionId')]"
            },
            "type": "Microsoft.Authorization/roleAssignments"
        }
    ]
}
