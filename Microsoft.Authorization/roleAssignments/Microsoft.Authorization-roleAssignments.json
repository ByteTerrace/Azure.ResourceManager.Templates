{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "principalId": {
            "metadata": {
                "description": "Specifies the principal id that will be granted rights on an Azure resource."
            },
            "type": "string"
        },
        "principalType": {
            "defaultValue": "ServicePrincipal",
            "metadata": {
                "description": "Specifies the principal type."
            },
            "type": "string"
        },
        "roleDefinitionIds": {
            "metadata": {
                "description": "Specifies the role definition ids that will be assigned to the principal."
            },
            "type": "array"
        }
    },
    "variables": {
        "authorizationRoleAssignmentsApiVersion":"[providers('Microsoft.Authorization', 'roleAssignments').apiVersions[0]]"
    },
    "resources": [
        {
            "apiVersion": "[variables('authorizationRoleAssignmentsApiVersion')]",
            "copy": {
                "count": "[length(parameters('roleDefinitionIds'))]",
                "mode": "parallel",
                "name": "roleAssignmentsCopy"
            },
            "name": "[guid(parameters('principalId'), parameters('roleDefinitionIds')[copyIndex()])]",
            "properties": {
                "canDelegate": false,
                "principalId": "[parameters('principalId')]",
                "principalType": "[parameters('principalType')]",
                "roleDefinitionId": "[parameters('roleDefinitionIds')[copyIndex()]]"
            },
            "type": "Microsoft.Authorization/roleAssignments"
        }
    ]
}
