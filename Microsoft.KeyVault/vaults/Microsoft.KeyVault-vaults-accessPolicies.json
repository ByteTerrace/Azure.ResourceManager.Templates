{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "actionType": {
            "allowedValues": [
                "add",
                "remove"
            ],
            "metadata": {
                "description": "Indicates whether permissions will be added or removed."
            },
            "type": "string"
        },
        "keyVaultName": {
            "metadata": {
                "description": "Specifies the name of the Azure Key Vault."
            },
            "type": "string"
        },
        "objectId": {
            "metadata": {
                "description": "Specifies the object id that will have its access policy modified in the Azure Key Vault."
            },
            "type": "string"
        },
        "permissions": {
            "metadata": {
                "description": "Specifies the permissions that will be modified."
            },
            "type": "object"
        },
        "tenantId": {
            "defaultValue": "[subscription().tenantId]",
            "metadata": {
                "description": "Specifies the tenant of the object that will have its access policy modified in the Azure Key Vault."
            },
            "type": "string"
        }
    },
    "variables": {
        "keyVaultAccessPolicyApiVersion": "2019-09-01"
    },
    "resources": [
        {
            "apiVersion": "[variables('keyVaultAccessPolicyApiVersion')]",
            "name": "[format('{0}/{1}', parameters('keyVaultName'), parameters('actionType'))]",
            "properties": {
                "accessPolicies": [
                    {
                        "objectId": "[parameters('objectId')]",
                        "permissions": "[parameters('permissions')]",
                        "tenantId": "[parameters('tenantId')]"
                    }
                ]
            },
            "type": "Microsoft.KeyVault/vaults/accessPolicies"
        }
    ]
}
