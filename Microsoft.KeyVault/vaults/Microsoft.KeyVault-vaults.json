{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "accessPolicies": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of access policies that will be assigned to the Azure Key Vault."
            },
            "type": "array"
        },
        "auditStorageAccountName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the name of the Azure Storage account that will be utilized by the audit feature."
            },
            "type": "string"
        },
        "auditStorageAccountResourceGroupName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the resource group name of the Azure Storage account that will be utilized by the audit feature."
            },
            "type": "string"
        },
        "firewallRules": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of firewall rules that will be assigned to the Azure Key Vault."
            },
            "type": "array"
        },
        "isAllowTrustedMicrosoftServicesEnabled": {
            "defaultValue": false,
            "metadata": {
                "description": "Indicates whether trusted Microsoft services are allowed to access the Azure Key Vault."
            },
            "type": "bool"
        },
        "keyVaultName": {
            "maxLength": 24,
            "metadata": {
                "description": "Specifies the name of the Azure Key Vault."
            },
            "minLength": 3,
            "type": "string"
        },
        "location": {
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Specifies the location in which the Azure Key Vault resource(s) should be deployed."
            },
            "type": "string"
        },
        "skuName": {
            "allowedValues": [
                "Premium",
                "Standard"
            ],
            "defaultValue": "Standard",
            "metadata": {
                "description": "Specifies the SKU name of the Azure Key Vault."
            },
            "type": "string"
        },
        "tenantId": {
            "defaultValue": "[subscription().tenantId]",
            "metadata": {
                "description": "Specifies the Azure Active Directory tenant GUID that should be used for authenticating requests to the Azure Key Vault."
            },
            "type": "string"
        },
        "tags": {
            "defaultValue": {},
            "metadata": {
                "description": "Specifies the set of tag key-value pairs that will be assigned to the Azure Key Vault."
            },
            "type": "object"
        },
        "virtualNetworkRules": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of virtual network rules that will be assigned to the Azure Key Vault."
            },
            "type": "array"
        }
    },
    "variables": {
        "auditStorageAccountName": "[toLower(if(not(empty(coalesce(parameters('auditStorageAccountName'), ''))), parameters('auditStorageAccountName'), 'DummyStorageAccountForAudit'))]",
        "auditStorageAccountResourceGroupName": "[if(not(empty(coalesce(parameters('auditStorageAccountResourceGroupName'), ''))), parameters('auditStorageAccountResourceGroupName'), resourceGroup().name)]",
        "auditStorageAccountResourceId": "[resourceId(variables('auditStorageAccountResourceGroupName'), 'Microsoft.Storage/storageAccounts', variables('auditStorageAccountName'))]",
        "copy": [
            {
                "count": "[length(parameters('firewallRules'))]",
                "input": {
                    "value": "[parameters('firewallRules')[copyIndex('firewallRules')]]"
                },
                "name": "firewallRules"
            },
            {
                "count": "[length(parameters('virtualNetworkRules'))]",
                "input": {
                    "id": "[resourceId(union(json(format('{{ \"virtualNetworkResourceGroupName\": \"{0}\" }}', resourceGroup().name)), parameters('virtualNetworkRules')[copyIndex('virtualNetworkRules')]).virtualNetworkResourceGroupName, 'Microsoft.Network/virtualNetworks/subnets', parameters('virtualNetworkRules')[copyIndex('virtualNetworkRules')].virtualNetworkName, parameters('virtualNetworkRules')[copyIndex('virtualNetworkRules')].subnetName)]"
                },
                "name": "virtualNetworkRules"
            }
        ],
        "diagnosticsSettingsApiVersion": "2017-05-01-preview",
        "firewallRulesIsNotEmpty": "[greater(length(parameters('firewallRules')), 0)]",
        "isAuditEnabled": "[variables('isAuditStorageAccountEnabled')]",
        "isAuditStorageAccountEnabled": "[or(not(empty(coalesce(parameters('auditStorageAccountResourceGroupName'), ''))), not(empty(coalesce(parameters('auditStorageAccountName'), ''))))]",
        "keyVaultApiVersion": "2018-02-14",
        "keyVaultResourceId": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
        "virtualNetworkRulesIsNotEmpty": "[greater(length(parameters('virtualNetworkRules')), 0)]"
    },
    "resources": [
        {
            "apiVersion": "[variables('keyVaultApiVersion')]",
            "location": "[parameters('location')]",
            "name": "[parameters('keyVaultName')]",
            "properties": {
                "accessPolicies": "[parameters('accessPolicies')]",
                "createMode": "default",
                "enabledForDeployment": false,
                "enabledForDiskEncryption": false,
                "enabledForTemplateDeployment": false,
                "enablePurgeProtection": true,
                "enableSoftDelete": true,
                "networkAcls": {
                    "bypass": "[if(parameters('isAllowTrustedMicrosoftServicesEnabled'), 'AzureServices', 'None')]",
                    "defaultAction": "Deny",
                    "ipRules": "[if(variables('firewallRulesIsNotEmpty'), variables('firewallRules'), json('null'))]",
                    "virtualNetworkRules": "[if(variables('virtualNetworkRulesIsNotEmpty'), variables('virtualNetworkRules'), json('null'))]"
                },
                "sku": {
                    "family": "A",
                    "name": "[parameters('skuName')]"
                },
                "tenantId": "[parameters('tenantId')]"
            },
            "tags": "[parameters('tags')]",
            "type": "Microsoft.KeyVault/vaults"
        },
        {
            "apiVersion": "[variables('diagnosticsSettingsApiVersion')]",
            "condition": "[variables('isAuditEnabled')]",
            "dependsOn": [
                "[variables('keyVaultResourceId')]"
            ],
            "location": "[parameters('location')]",
            "name": "[format('{0}/Microsoft.Insights/audit', parameters('keyVaultName'))]",
            "properties": {
                "logs": [
                    {
                        "category": "AuditEvent",
                        "enabled": true,
                        "retentionPolicy": {
                            "days": 365,
                            "enabled": true
                        }
                    }
                ],
                "storageAccountId": "[variables('auditStorageAccountResourceId')]"
            },
            "type": "Microsoft.KeyVault/vaults/providers/diagnosticsettings"
        }
    ]
}
