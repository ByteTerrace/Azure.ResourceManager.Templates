{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "2.0.0.0",
    "parameters": {
        "accessPolicies": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of access policies that will be assigned to the Azure Key Vault."
            },
            "type": "array"
        },
        "firewallRules": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of firewall rules that will be assigned to the Azure Key Vault."
            },
            "type": "array"
        },
        "isAllowTrustedMicrosoftServicesEnabled": {
            "defaultValue": false,
            "metadata": {
                "description": "Indicates whether trusted Microsoft services are allowed to access the Azure Key Vault."
            },
            "type": "bool"
        },
        "isDiskEncryptionEnabled": {
            "defaultValue": false,
            "metadata": {
                "description": "Indicates whether Azure Disk Encryption is permitted to retrieve secrets and upwrap keys in the Azure Key Vault."
            },
            "type": "bool"
        },
        "isPurgeProtectionEnabled": {
            "defaultValue": true,
            "metadata": {
                "description": "Indicates whether the purge protection feature is enabled on the Azure Key Vault."
            },
            "type": "bool"
        },
        "isSoftDeleteEnabled": {
            "defaultValue": true,
            "metadata": {
                "description": "Indicates whether the soft-delete feature is enabled on the Azure Key Vault."
            },
            "type": "bool"
        },
        "isTemplateDeploymentEnabled": {
            "defaultValue": false,
            "metadata": {
                "description": "Indicates whether Azure Resource Manager is permitted to access secrets from the Azure Key Vault."
            },
            "type": "bool"
        },
        "isVirtualMachineDeploymentEnabled": {
            "defaultValue": false,
            "metadata": {
                "description": "Indicates whether Azure virtual machines are able to retrieve certificates stored as secrets from the Azure Key Vault."
            },
            "type": "bool"
        },
        "keyVaultName": {
            "maxLength": 24,
            "metadata": {
                "description": "Specifies the name of the Azure Key Vault."
            },
            "minLength": 3,
            "type": "string"
        },
        "location": {
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Specifies the location in which the Azure Key Vault resource(s) will be deployed."
            },
            "type": "string"
        },
        "skuName": {
            "allowedValues": [
                "Premium",
                "Standard"
            ],
            "defaultValue": "Standard",
            "metadata": {
                "description": "Specifies the SKU name of the Azure Key Vault."
            },
            "type": "string"
        },
        "tenantId": {
            "defaultValue": "[subscription().tenantId]",
            "metadata": {
                "description": "Specifies the Azure Active Directory tenant GUID that will be used for authenticating requests to the Azure Key Vault."
            },
            "type": "string"
        },
        "secrets": {
            "defaultValue": {},
            "metadata": {
                "description": "An object that encapsulates the array of secrets that will be stored within the Azure Key Vault."
            },
            "type": "secureObject"
        },
        "tags": {
            "defaultValue": {},
            "metadata": {
                "description": "Specifies the set of tag key-value pairs that will be assigned to the Azure Key Vault."
            },
            "type": "object"
        },
        "virtualNetworkRules": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of virtual network rules that will be assigned to the Azure Key Vault."
            },
            "type": "array"
        }
    },
    "variables": {
        "copy": [
            {
                "count": "[length(parameters('accessPolicies'))]",
                "input": {
                    "applicationId": "[union(json('{ \"applicationId\": null }'), parameters('accessPolicies')[copyIndex('accessPolicies')]).applicationId]",
                    "objectId": "[parameters('accessPolicies')[copyIndex('accessPolicies')].objectId]",
                    "permissions": "[parameters('accessPolicies')[copyIndex('accessPolicies')].permissions]",
                    "tenantId": "[union(json(format('{{ \"tenantId\": \"{0}\" }}', subscription().tenantId)), parameters('accessPolicies')[copyIndex('accessPolicies')]).tenantId]"
                },
                "name": "accessPolicies"
            },
            {
                "count": "[length(parameters('firewallRules'))]",
                "input": {
                    "value": "[parameters('firewallRules')[copyIndex('firewallRules')]]"
                },
                "name": "firewallRules"
            },
            {
                "count": "[length(parameters('virtualNetworkRules'))]",
                "input": {
                    "id": "[resourceId(union(json(format('{{ \"subscriptionId\": \"{0}\" }}', subscription().subscriptionId)), parameters('virtualNetworkRules')[copyIndex('virtualNetworkRules')]).subscriptionId, union(json(format('{{ \"resourceGroupName\": \"{0}\" }}', resourceGroup().name)), parameters('virtualNetworkRules')[copyIndex('virtualNetworkRules')]).resourceGroupName, 'Microsoft.Network/virtualNetworks/subnets', parameters('virtualNetworkRules')[copyIndex('virtualNetworkRules')].virtualNetworkName, parameters('virtualNetworkRules')[copyIndex('virtualNetworkRules')].subnetName)]"
                },
                "name": "virtualNetworkRules"
            }
        ],
        "firewallRulesIsNotEmpty": "[greater(length(parameters('firewallRules')), 0)]",
        "keyVaultApiVersion": "2019-09-01",
        "keyVaultResourceId": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
        "secretsApiVersion": "2019-09-01",
        "secretsArray": "[if(variables('secretsArrayIsNotEmpty'), parameters('secrets').array, json('[ { \"name\":\"dummySecret\", \"value\": \"Shhh, don''t tell anyone...\" } ]'))]",
        "secretsArrayCount": "[length(union(json('{ \"array\": [] }'), parameters('secrets')).array)]",
        "secretsArrayIsNotEmpty": "[greater(variables('secretsArrayCount'), 0)]",
        "virtualNetworkRulesIsNotEmpty": "[greater(length(parameters('virtualNetworkRules')), 0)]"
    },
    "resources": [
        {
            "apiVersion": "[variables('keyVaultApiVersion')]",
            "location": "[parameters('location')]",
            "name": "[parameters('keyVaultName')]",
            "properties": {
                "accessPolicies": "[variables('accessPolicies')]",
                "createMode": "default",
                "enabledForDeployment": "[parameters('isVirtualMachineDeploymentEnabled')]",
                "enabledForDiskEncryption": "[parameters('isDiskEncryptionEnabled')]",
                "enabledForTemplateDeployment": "[parameters('isTemplateDeploymentEnabled')]",
                "enablePurgeProtection": "[parameters('isPurgeProtectionEnabled')]",
                "enableSoftDelete": "[parameters('isSoftDeleteEnabled')]",
                "networkAcls": {
                    "bypass": "[if(parameters('isAllowTrustedMicrosoftServicesEnabled'), 'AzureServices', 'None')]",
                    "defaultAction": "Deny",
                    "ipRules": "[if(variables('firewallRulesIsNotEmpty'), variables('firewallRules'), json('null'))]",
                    "virtualNetworkRules": "[if(variables('virtualNetworkRulesIsNotEmpty'), variables('virtualNetworkRules'), json('null'))]"
                },
                "sku": {
                    "family": "A",
                    "name": "[parameters('skuName')]"
                },
                "tenantId": "[parameters('tenantId')]"
            },
            "tags": "[parameters('tags')]",
            "type": "Microsoft.KeyVault/vaults"
        },
        {
            "apiVersion": "[variables('secretsApiVersion')]",
            "condition": "[variables('secretsArrayIsNotEmpty')]",
            "copy": {
                "count": "[variables('secretsArrayCount')]",
                "name": "secretsCopy"
            },
            "dependsOn": [
                "[variables('keyVaultResourceId')]"
            ],
            "name": "[format('{0}/{1}', parameters('keyVaultName'), variables('secretsArray')[copyIndex()].name)]",
            "properties": {
                "value": "[variables('secretsArray')[copyIndex()].value]"
            },
            "type": "Microsoft.KeyVault/vaults/secrets"
        }
    ]
}
