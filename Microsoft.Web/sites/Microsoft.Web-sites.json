{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "applicationSettings": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of application settings that will be associated with the Azure Web site."
            },
            "type": "array"
        },
        "functionVersion": {
            "allowedValues": [
                "~1",
                "~2",
                "~3"
            ],
            "defaultValue": "~3",
            "metadata": {
                "description": "Specifies the version of the function extensions that will be used with the Azure Web site."
            },
            "type": "string"
        },
        "healthCheckPath": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the path that will be pinged by the Azure web site health check feature."
            },
            "type": "string"
        },
        "isAlwaysOnEnabled": {
            "defaultValue": true,
            "metadata": {
                "description": "Indicates whether the always on feature is enabled on the Azure Web site."
            },
            "type": "bool"
        },
        "isClientAffinityEnabled": {
            "defaultValue": false,
            "metadata": {
                "description": "Indicates whether the client affinity feature is enabled on the Azure Web site."
            },
            "type": "bool"
        },
        "isWebSocketsEnabled": {
            "defaultValue": true,
            "metadata": {
                "description": "Indicates whether the web sockets feature is enabled on the Azure Web site."
            },
            "type": "bool"
        },
        "is32BitModeEnabled": {
            "defaultValue": true,
            "metadata": {
                "description": "Indicates whether the 32-bit worker feature is enabled on the Azure Web site."
            },
            "type": "bool"
        },
        "kind": {
            "allowedValues": [
                "app",
                "functionApp"
            ],
            "defaultValue": "app",
            "metadata": {
                "description": "Specifies the kind of Azure Web site."
            },
            "type": "string"
        },
        "location": {
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Specifies the location in which the Azure Web site resource(s) should be deployed."
            },
            "type": "string"
        },
        "operatingSystemName": {
            "allowedValues": [
                "Linux",
                "Windows"
            ],
            "defaultValue": "Linux",
            "metadata": {
                "description": "Specifies the name of operating system that the Azure Web site will run within."
            },
            "type": "string"
        },
        "servicePlanName": {
            "metadata": {
                "description": "Specifies the name of the Azure Web app service plan that the Azure Web site will be deployed within."
            },
            "type": "string"
        },
        "servicePlanResourceGroupName": {
            "defaultValue": "[resourceGroup().name]",
            "metadata": {
                "description": "Specifies the resource group name of the Azure Web app service plan that the Azure Web site will be deployed within."
            },
            "type": "string"
        },
        "siteName": {
            "maxLength": 60,
            "metadata": {
                "description": "Specifies the name of the Azure Web site."
            },
            "minLength": 2,
            "type": "string"
        },
        "slots": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of slots that will be associated with the Azure Web site."
            },
            "type": "array"
        },
        "stack": {
            "allowedValues": [
                "dotnetcore"
            ],
            "defaultValue": "dotnetcore",
            "metadata": {
                "description": "Specifies the name of the stack that Azure Web site will be run on top of."
            },
            "type": "string"
        },
        "subnetName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the name of the subnet that will be integrated with the Azure Web site."
            },
            "type": "string"
        },
        "tags": {
            "defaultValue": {},
            "metadata": {
                "description": "Specifies the set of tag key-value pairs that will be assigned to the Azure Web site."
            },
            "type": "object"
        },
        "virtualNetworkName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the name of the Azure Virtual Network that will be integrated with the Azure Web site."
            },
            "type": "string"
        },
        "virtualNetworkResourceGroupName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the resource group name of the Azure Virtual Network that will be integrated with the Azure Web site."
            },
            "type": "string"
        }
    },
    "variables": {
        "applicationSettingsSlotNames": "[union(variables('applicationSettingsSlotNamesTemp'), json('[\"\"]'))]",
        "copy": [
            {
                "count": "[length(parameters('applicationSettings'))]",
                "input": {
                    "name": "[parameters('applicationSettings')[copyIndex('applicationSettings')].name]",
                    "value": "[parameters('applicationSettings')[copyIndex('applicationSettings')].value]"
                },
                "name": "applicationSettings"
            },
            {
                "count": "[length(parameters('applicationSettings'))]",
                "input": "[if(parameters('applicationSettings')[copyIndex('applicationSettingsSlotNamesTemp')].isSlotSetting, parameters('applicationSettings')[copyIndex('applicationSettingsSlotNamesTemp')].name, '')]",
                "name": "applicationSettingsSlotNamesTemp"
            }
        ],
        "deploymentApiVersion": "2019-10-01",
        "functionAppSettings": [
            {
                "name": "FUNCTIONS_EXTENSION_VERSION",
                "value": "[parameters('functionVersion')]"
            },
            {
                "name": "FUNCTIONS_WORKER_RUNTIME",
                "value": "dotnet"
            }
        ],
        "ipSecurityRestrictions": [
            {
                "action": "Allow",
                "priority": 1,
                "name": "default",
                "tag": "Default",
                "vnetSubnetResourceId": "[variables('virtualNetworkResourceId')]"
            }
        ],
        "isFunctionApp": "[equals('functionapp', toLower(parameters('kind')))]",
        "isHealthCheckEnabled": "[not(empty(coalesce(parameters('healthCheckPath'), '')))]",
        "isLinuxOperatingSystem": "[equals('linux', toLower(parameters('operatingSystemName')))]",
        "isVirtualNetworkIntegrationEnabled": "[or(not(empty(coalesce(parameters('virtualNetworkResourceGroupName')))), not(empty(coalesce(parameters('virtualNetworkName')))), not(empty(coalesce(parameters('subnetName')))))]",
        "servicePlanResourceGroupName": "[if(not(empty(coalesce(parameters('servicePlanResourceGroupName'), ''))), parameters('servicePlanResourceGroupName'), resourceGroup().name)]",
        "servicePlanResourceId": "[resourceId(variables('servicePlanResourceGroupName'), 'Microsoft.Web/serverfarms', parameters('servicePlanName'))]",
        "siteKind": "[format('{0}{1}', parameters('kind'), if(variables('isLinuxOperatingSystem'), ',linux', ''))]",
        "siteConfigForVirtualNetworkResourceId": "[resourceId('Microsoft.Web/sites/config', parameters('siteName'), 'virtualNetwork')]",
        "siteConfigForWebResourceId": "[resourceId('Microsoft.Web/sites/config', parameters('siteName'), 'virtualNetwork')]",
        "siteResourceId": "[resourceId('Microsoft.Web/sites', parameters('siteName'))]",
        "sitesApiVersion": "2019-08-01",
        "sitesConfigApiVersion": "2019-08-01",
        "slots": "[if(variables('slotsIsNotEmpty'), parameters('slots'), json('[ { \"slotName\": \"DummySlot\" } ]'))]",
        "slotsApiVersion": "2019-08-01",
        "slotsIsNotEmpty": "[greater(length(parameters('slots')), 0)]",
        "virtualNetworkResourceGroupName": "[if(not(empty(coalesce(parameters('virtualNetworkResourceGroupName'), ''))), parameters('virtualNetworkResourceGroupName'), resourceGroup().name)]",
        "virtualNetworkResourceId": "[resourceId(variables('virtualNetworkResourceGroupName'), 'Microsoft.Network/virtualNetworks/subnets', parameters('virtualNetworkName'), parameters('subnetName'))]"
    },
    "resources": [
        {
            "apiVersion": "[variables('sitesApiVersion')]",
            "kind": "[variables('siteKind')]",
            "location": "[parameters('location')]",
            "name": "[parameters('siteName')]",
            "properties": {
                "serverFarmId": "[variables('servicePlanResourceId')]",
                "siteConfig": {
                    "alwaysOn": "[parameters('isAlwaysOnEnabled')]",
                    "appsettings": "[if(variables('isFunctionApp'), variables('functionAppSettings'), json('[]'))]",
                    "clientAffinityEnabled": "[parameters('isClientAffinityEnabled')]",
                    "ftpsState": "FtpsOnly",
                    "healthCheckPath": "[if(variables('isHealthCheckEnabled'), parameters('healthCheckPath'), '')]",
                    "httpsOnly": true,
                    "http20Enabled": true,
                    "linuxFxVersion": "[if(variables('isLinuxOperatingSystem'), 'DOTNETCORE|LTS', json('null'))]",
                    "metadata": [
                        {
                            "name": "CURRENT_STACK",
                            "value": "[parameters('stack')]"
                        }
                    ],
                    "minTlsVersion": "1.2",
                    "use32BitWorkerProcess": "[parameters('is32BitModeEnabled')]",
                    "webSocketsEnabled": "[parameters('isWebSocketsEnabled')]"
                }
            },
            "tags": "[parameters('tags')]",
            "type": "Microsoft.Web/sites"
        },
        {
            "apiVersion": "[variables('sitesConfigApiVersion')]",
            "dependsOn": [
                "[variables('siteResourceId')]"
            ],
            "name": "[format('{0}/slotConfigNames', parameters('siteName'))]",
            "properties": {
                "appSettingNames": "[take(variables('applicationSettingsSlotNames'), sub(length(variables('applicationSettingsSlotNames')), 1))]"
            },
            "type": "Microsoft.Web/sites/config"
        },
        {
            "apiVersion": "[variables('sitesConfigApiVersion')]",
            "condition": "[variables('isVirtualNetworkIntegrationEnabled')]",
            "dependsOn": [
                "[variables('siteResourceId')]"
            ],
            "name": "[format('{0}/virtualNetwork', parameters('siteName'))]",
            "properties": {
                "subnetResourceId": "[variables('virtualNetworkResourceId')]",
                "swiftSupported": true
            },
            "type": "Microsoft.Web/sites/config"
        },
        {
            "apiVersion": "[variables('sitesConfigApiVersion')]",
            "dependsOn": [
                "[variables('siteResourceId')]"
            ],
            "name": "[format('{0}/web', parameters('siteName'))]",
            "properties": {
                "ipSecurityRestrictions": "[if(variables('isVirtualNetworkIntegrationEnabled'), variables('ipSecurityRestrictions'), json('[]'))]",
                "scmIpSecurityRestrictions": null,
                "scmIpSecurityRestrictionsUseMain": true
            },
            "type": "Microsoft.Web/sites/config"
        },
        {
            "apiVersion": "[variables('slotsApiVersion')]",
            "condition": false,
            "copy": {
                "count": "[length(variables('slots'))]",
                "mode": "parallel",
                "name": "slotsCopy"
            },
            "dependsOn": [
                "[variables('siteResourceId')]",
                "[variables('siteConfigForVirtualNetworkResourceId')]",
                "[variables('siteConfigForWebResourceId')]"
            ],
            "kind": "[variables('siteKind')]",
            "location": "[parameters('location')]",
            "name": "[format('{0}/{1}', parameters('siteName'), variables('slots')[copyIndex()].slotName)]",
            "tags": "[parameters('tags')]",
            "properties": {
                "cloningInfo": {
                    "cloneCustomHostNames": false,
                    "cloneSourceControl": false,
                    "configureLoadBalancing": false,
                    "overwrite": true,
                    "sourceWebAppId": "[variables('siteResourceId')]"
                },
                "serverFarmId": "[variables('servicePlanResourceId')]"
            },
            "type": "Microsoft.Web/sites/slots"
        }
    ]
}
