{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Specifies the location in which the Azure Web site resource(s) should be deployed."
            },
            "type": "string"
        },
        "siteName": {
            "metadata": {
                "description": "Specifies the name of the Azure Web site."
            },
            "type": "string"
        },
        "subnetName": {
            "metadata": {
                "description": "Specifies the name of the subnet that will be integrated with the Azure Web site."
            },
            "type": "string"
        },
        "virtualNetworkName": {
            "metadata": {
                "description": "Specifies the name of the Azure Virtual Network that will be integrated with the Azure Web site."
            },
            "type": "string"
        },
        "virtualNetworkResourceGroupName": {
            "metadata": {
                "description": "Specifies the resource group name of the Azure Virtual Network that will be integrated with the Azure Web site."
            },
            "type": "string"
        }
    },
    "variables": {
        "virtualNetworkConnectionsApiVersion": "2019-08-01"
    },
    "resources": [
        {
            "apiVersion": "[variables('virtualNetworkConnectionsApiVersion')]",
            "location": "[parameters('location')]",
            "name": "[format('{0}/default', parameters('siteName'))]",
            "properties": {
                "isSwift": true,
                "vnetResourceId": "[resourceId(parameters('virtualNetworkResourceGroupName'), 'Microsoft.Network/virtualNetworks/subnets', parameters('virtualNetworkName'), parameters('subnetName'))]"
            },
            "type": "Microsoft.Web/sites/virtualNetworkConnections"
        }
    ]
}
