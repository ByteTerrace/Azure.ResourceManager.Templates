{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Specifies the location in which the Azure Web app service plan resource(s) should be deployed."
            },
            "type": "string"
        },
        "operatingSystemName": {
            "allowedValues": [
                "Linux",
                "Windows"
            ],
            "defaultValue": "Linux",
            "metadata": {
                "description": "Specifies the name of operating system that the Azure Web app service plan will run within."
            },
            "type": "string"
        },
        "serviceEnvironmentName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the name of the environment that the Azure Web app service plan will be hosted within."
            },
            "type": "string"
        },
        "serviceEnvironmentResourceGroupName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the resource group name of the environment that the Azure Web app service plan will be hosted within."
            },
            "type": "string"
        },
        "servicePlanName": {
            "maxLength": 40,
            "metadata": {
                "description": "Specifies the name of the Azure Web app service plan."
            },
            "minLength": 1,
            "type": "string"
        },
        "sites": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of sites that will be created within the Azure Web app service plan."
            },
            "type": "array"
        },
        "skuName": {
            "allowedValues": [
                "B1",
                "B2",
                "B3",
                "D1",
                "F1",
                "I1",
                "I2",
                "I3",
                "P1",
                "P1V2",
                "P2",
                "P2V2",
                "P3",
                "P3V2",
                "S1",
                "S2",
                "S3",
                "Y1"
            ],
            "defaultValue": "F1",
            "metadata": {
                "description": "Specifies the SKU name of the Azure Web app service plan."
            },
            "type": "string"
        },
        "tags": {
            "defaultValue": {},
            "metadata": {
                "description": "Specifies the set of tag key-value pairs that will be assigned to the Azure Web app service plan."
            },
            "type": "object"
        }
    },
    "variables": {
        "deploymentApiVersion": "2019-10-01",
        "hostingEnvironmentProfile": {
            "id": "[variables('serviceEnvironmentResourceId')]"
        },
        "isHostingEnvironmentEnabled": "[or(not(empty(coalesce(parameters('serviceEnvironmentResourceGroupName'), ''))), not(empty(coalesce(parameters('serviceEnvironmentName'), ''))))]",
        "isLinuxOperatingSystem": "[equals('linux', toLower(parameters('operatingSystemName')))]",
        "serverFarmApiVersion": "2019-08-01",
        "serverFarmResourceId": "[resourceId('Microsoft.Web/serverfarms/', parameters('servicePlanName'))]",
        "serviceEnvironmentName": "[if(not(empty(coalesce(parameters('serviceEnvironmentName'), ''))), parameters('serviceEnvironmentName'), 'DummyServiceEnvironment')]",
        "serviceEnvironmentResourceGroupName": "[if(not(empty(coalesce(parameters('serviceEnvironmentResourceGroupName'), ''))), parameters('serviceEnvironmentResourceGroupName'), resourceGroup().name)]",
        "serviceEnvironmentResourceId": "[resourceId(variables('serviceEnvironmentResourceGroupName'), 'Microsoft.Web/hostingEnvironments/', variables('serviceEnvironmentName'))]",
        "siteApiVersion": "2019-08-01",
        "sites": "[if(variables('sitesIsNotEmpty'), parameters('sites'), json('[ { \"siteName\": \"DummySite\" } ]'))]",
        "sitesCount": "[length(parameters('sites'))]",
        "sitesIsNotEmpty": "[greater(variables('sitesCount'), 0)]",
        "sitesTemplateUri": "https://dev.azure.com/ByteTerrace/Azure/_apis/git/repositories/Azure.ResourceManager.Templates/Items?path=%2FMicrosoft.Web%2Fsites%2FMicrosoft.Web-sites.json&recursionLevel=0&versionDescriptor.version=master&versionDescriptor.versionOptions=0&versionDescriptor.versionType=0&includeContent=true&resolveLfs=true"
    },
    "resources": [
        {
            "apiVersion": "[variables('serverFarmApiVersion')]",
            "kind": "[if(variables('isLinuxOperatingSystem'), 'linux', '')]",
            "location": "[parameters('location')]",
            "name": "[parameters('servicePlanName')]",
            "properties": {
                "hostingEnvironmentProfile": "[if(variables('isHostingEnvironmentEnabled'), variables('hostingEnvironmentProfile'), json('null'))]",
                "hyperV": false,
                "isSpot": false,
                "isXenon": false,
                "perSiteScaling": false,
                "reserved": "[variables('isLinuxOperatingSystem')]"
            },
            "sku": {
                "name": "[parameters('skuName')]"
            },
            "tags": "[parameters('tags')]",
            "type": "Microsoft.Web/serverfarms"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "condition": "[variables('sitesIsNotEmpty')]",
            "copy": {
                "count": "[variables('sitesCount')]",
                "mode": "parallel",
                "name": "sitesCopy"
            },
            "dependsOn": [
                "[variables('serverFarmResourceId')]"
            ],
            "name": "[format('{0}-sites-{1}', deployment().name, variables('sites')[copyIndex()].siteName)]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "functionVersion": {
                        "value": "[union(json('{ \"functionVersion\": \"~3\" }'), variables('sites')[copyIndex()]).functionVersion]"
                    },
                    "isAlwaysOnEnabled": {
                        "value": "[union(json('{ \"isAlwaysOnEnabled\": true }'), variables('sites')[copyIndex()]).isAlwaysOnEnabled]"
                    },
                    "isClientAffinityEnabled": {
                        "value": "[union(json('{ \"isClientAffinityEnabled\": false }'), variables('sites')[copyIndex()]).isClientAffinityEnabled]"
                    },
                    "isWebSocketsEnabled": {
                        "value": "[union(json('{ \"isWebSocketsEnabled\": true }'), variables('sites')[copyIndex()]).isWebSocketsEnabled]"
                    },
                    "is32BitModeEnabled": {
                        "value": "[union(json('{ \"is32BitModeEnabled\": false }'), variables('sites')[copyIndex()]).is32BitModeEnabled]"
                    },
                    "kind": {
                        "value": "[union(json('{ \"kind\": \"app\" }'), variables('sites')[copyIndex()]).kind]"
                    },
                    "location": {
                        "value": "[parameters('location')]"
                    },
                    "operatingSystemName": {
                        "value": "[parameters('operatingSystemName')]"
                    },
                    "servicePlanName": {
                        "value": "[parameters('servicePlanName')]"
                    },
                    "siteName": {
                        "value": "[variables('sites')[copyIndex()].siteName]"
                    },
                    "slots": {
                        "value": "[union(json('[]'), variables('sites')[copyIndex()]).slots]"
                    },
                    "stack": {
                        "value": "[union(json('{ \"stack\": \"dotnetcore\" }'), variables('sites')[copyIndex()]).stack]"
                    },
                    "subnetName": {
                        "value": "[union(json('{ \"subnetName\": \"\" }'), variables('sites')[copyIndex()]).subnetName]"
                    },
                    "tags": {
                        "value": "[parameters('tags')]"
                    },
                    "virtualNetworkName": {
                        "value": "[union(json('{ \"virtualNetworkName\": \"\" }'), variables('sites')[copyIndex()]).virtualNetworkName]"
                    },
                    "virtualNetworkResourceGroupName": {
                        "value": "[union(json('{ \"virtualNetworkResourceGroupName\": \"\" }'), variables('sites')[copyIndex()]).virtualNetworkResourceGroupName]"
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('sitesTemplateUri')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        }
    ]
}
