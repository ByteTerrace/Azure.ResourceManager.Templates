{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "2.0.0.0",
    "parameters": {
        "applicationSettings": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of application settings that will be associated with the Azure Web site."
            },
            "type": "array"
        },
        "connectionStrings": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of connecion strings that will be associated with the Azure Web site."
            },
            "type": "array"
        },
        "functionVersion": {
            "allowedValues": [
                "~1",
                "~2",
                "~3"
            ],
            "defaultValue": "~3",
            "metadata": {
                "description": "Specifies the version of the function extensions that will be used with the Azure Web site."
            },
            "type": "string"
        },
        "healthCheckPath": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the path that will be pinged by the Azure web site health check feature."
            },
            "type": "string"
        },
        "isAlwaysOnEnabled": {
            "defaultValue": true,
            "metadata": {
                "description": "Indicates whether the always on feature is enabled on the Azure Web site."
            },
            "type": "bool"
        },
        "isClientAffinityEnabled": {
            "defaultValue": false,
            "metadata": {
                "description": "Indicates whether the client affinity feature is enabled on the Azure Web site."
            },
            "type": "bool"
        },
        "isProductionSlotDeploymentEnabled": {
            "defaultValue": true,
            "metadata": {
                "description": "Indicates whether the production slot of the Azure Web site will be deployed."
            },
            "type": "bool"
        },
        "isWebSocketsEnabled": {
            "defaultValue": true,
            "metadata": {
                "description": "Indicates whether the web sockets feature is enabled on the Azure Web site."
            },
            "type": "bool"
        },
        "is32BitModeEnabled": {
            "defaultValue": true,
            "metadata": {
                "description": "Indicates whether the 32-bit worker feature is enabled on the Azure Web site."
            },
            "type": "bool"
        },
        "keyVaultPermissions": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of Azure Key Vault access policy permissions that will be granted to the Azure Web site slot."
            },
            "type": "array"
        },
        "kind": {
            "allowedValues": [
                "app",
                "functionApp"
            ],
            "defaultValue": "app",
            "metadata": {
                "description": "Specifies the kind of Azure Web site."
            },
            "type": "string"
        },
        "linkedTemplateBaseUri": {
            "defaultValue": "https://dev.azure.com/ByteTerrace/Azure/_apis/git/repositories/Azure.ResourceManager.Templates/",
            "metadata": {
                "description": "Specifies the base uri of external linked templates used by this template."
            },
            "type": "string"
        },
        "linkedTemplateQueryString": {
            "defaultValue": "&recursionLevel=0&versionDescriptor.version=master&versionDescriptor.versionOptions=0&versionDescriptor.versionType=0&includeContent=true&resolveLfs=true",
            "metadata": {
                "description": "Specifies the query string that will be appended to the uri of external linked templates used by this template."
            },
            "type": "string"
        },
        "location": {
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Specifies the location in which the Azure Web site resource(s) should be deployed."
            },
            "type": "string"
        },
        "operatingSystemName": {
            "allowedValues": [
                "Linux",
                "Windows"
            ],
            "defaultValue": "Linux",
            "metadata": {
                "description": "Specifies the name of operating system that the Azure Web site will run within."
            },
            "type": "string"
        },
        "servicePlanName": {
            "metadata": {
                "description": "Specifies the name of the Azure Web app service plan that the Azure Web site will be deployed within."
            },
            "type": "string"
        },
        "servicePlanResourceGroupName": {
            "defaultValue": "[resourceGroup().name]",
            "metadata": {
                "description": "Specifies the resource group name of the Azure Web app service plan that the Azure Web site will be deployed within."
            },
            "type": "string"
        },
        "siteName": {
            "maxLength": 60,
            "metadata": {
                "description": "Specifies the name of the Azure Web site."
            },
            "minLength": 2,
            "type": "string"
        },
        "slots": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of slots that will be associated with the Azure Web site."
            },
            "type": "array"
        },
        "stack": {
            "allowedValues": [
                "dotnetcore"
            ],
            "defaultValue": "dotnetcore",
            "metadata": {
                "description": "Specifies the name of the stack that Azure Web site will be run on top of."
            },
            "type": "string"
        },
        "subnetName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the name of the subnet that will be integrated with the Azure Web site."
            },
            "type": "string"
        },
        "tags": {
            "defaultValue": {},
            "metadata": {
                "description": "Specifies the set of tag key-value pairs that will be assigned to the Azure Web site."
            },
            "type": "object"
        },
        "virtualNetworkName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the name of the Azure Virtual Network that will be integrated with the Azure Web site."
            },
            "type": "string"
        },
        "virtualNetworkResourceGroupName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the resource group name of the Azure Virtual Network that will be integrated with the Azure Web site."
            },
            "type": "string"
        }
    },
    "variables": {
        "applicationSettingsSlotNames": "[union(json('[\"\"]'), variables('applicationSettingsSlotNamesTemp'))]",
        "connectionStringsSlotNames": "[union(json('[\"\"]'), variables('connectionStringsSlotNamesTemp'))]",
        "copy": [
            {
                "count": "[length(parameters('applicationSettings'))]",
                "input": {
                    "name": "[parameters('applicationSettings')[copyIndex('applicationSettings')].name]",
                    "value": "[parameters('applicationSettings')[copyIndex('applicationSettings')].value]"
                },
                "name": "applicationSettings"
            },
            {
                "count": "[length(parameters('applicationSettings'))]",
                "input": "[if(parameters('applicationSettings')[copyIndex('applicationSettingsSlotNamesTemp')].isSlotSetting, parameters('applicationSettings')[copyIndex('applicationSettingsSlotNamesTemp')].name, '')]",
                "name": "applicationSettingsSlotNamesTemp"
            },
            {
                "count": "[length(parameters('connectionStrings'))]",
                "input": {
                    "connectionString": "[parameters('connectionStrings')[copyIndex('connectionStrings')].value]",
                    "name": "[parameters('connectionStrings')[copyIndex('connectionStrings')].name]",
                    "type": "[parameters('connectionStrings')[copyIndex('connectionStrings')].type]"
                },
                "name": "connectionStrings"
            },
            {
                "count": "[length(parameters('connectionStrings'))]",
                "input": "[if(parameters('connectionStrings')[copyIndex('connectionStringsSlotNamesTemp')].isSlotSetting, parameters('connectionStrings')[copyIndex('connectionStringsSlotNamesTemp')].name, '')]",
                "name": "connectionStringsSlotNamesTemp"
            }
        ],
        "deploymentApiVersion": "2019-10-01",
        "functionAppSettings": [
            {
                "name": "FUNCTIONS_EXTENSION_VERSION",
                "value": "[parameters('functionVersion')]"
            },
            {
                "name": "FUNCTIONS_WORKER_RUNTIME",
                "value": "dotnet"
            }
        ],
        "ipSecurityRestrictions": [
            {
                "action": "Allow",
                "priority": 1,
                "name": "default",
                "tag": "Default",
                "vnetSubnetResourceId": "[variables('virtualNetworkResourceId')]"
            }
        ],
        "isFunctionApp": "[equals('functionapp', toLower(parameters('kind')))]",
        "isHealthCheckEnabled": "[not(empty(coalesce(parameters('healthCheckPath'), '')))]",
        "isLinuxOperatingSystem": "[equals('linux', toLower(parameters('operatingSystemName')))]",
        "isVirtualNetworkIntegrationEnabled": "[or(not(empty(coalesce(parameters('virtualNetworkResourceGroupName')))), not(empty(coalesce(parameters('virtualNetworkName')))), not(empty(coalesce(parameters('subnetName')))))]",
        "keyVaultPermissions": "[if(variables('keyVaultPermissionsIsNotEmpty'), parameters('keyVaultPermissions'), json('[ { \"keyVaultName\": \"dummyKeyVault\", \"permissions\": [] } ]'))]",
        "keyVaultPermissionsCount": "[length(parameters('keyVaultPermissions'))]",
        "keyVaultPermissionsIsNotEmpty": "[greater(variables('keyVaultPermissionsCount'), 0)]",
        "servicePlanResourceGroupName": "[if(not(empty(coalesce(parameters('servicePlanResourceGroupName'), ''))), parameters('servicePlanResourceGroupName'), resourceGroup().name)]",
        "servicePlanResourceId": "[resourceId(variables('servicePlanResourceGroupName'), 'Microsoft.Web/serverfarms', parameters('servicePlanName'))]",
        "siteConfigForRoot": {
            "alwaysOn": "[parameters('isAlwaysOnEnabled')]",
            "appsettings": "[concat(variables('applicationSettings'), if(variables('isFunctionApp'), variables('functionAppSettings'), json('[]')))]",
            "connectionStrings": "[variables('connectionStrings')]",
            "ftpsState": "FtpsOnly",
            "healthCheckPath": "[if(variables('isHealthCheckEnabled'), parameters('healthCheckPath'), '')]",
            "httpsOnly": true,
            "http20Enabled": true,
            "linuxFxVersion": "[if(variables('isLinuxOperatingSystem'), 'DOTNETCORE|LTS', json('null'))]",
            "metadata": [
                {
                    "name": "CURRENT_STACK",
                    "value": "[parameters('stack')]"
                }
            ],
            "minTlsVersion": "1.2",
            "use32BitWorkerProcess": "[parameters('is32BitModeEnabled')]",
            "webSocketsEnabled": "[parameters('isWebSocketsEnabled')]"
        },
        "siteConfigForVirtualNetworkProperties": {
            "subnetResourceId": "[variables('virtualNetworkResourceId')]",
            "swiftSupported": true
        },
        "siteConfigForWebProperties": {
            "ipSecurityRestrictions": "[if(variables('isVirtualNetworkIntegrationEnabled'), variables('ipSecurityRestrictions'), json('[]'))]",
            "scmIpSecurityRestrictions": null,
            "scmIpSecurityRestrictionsUseMain": true
        },
        "siteKind": "[format('{0}{1}', parameters('kind'), if(variables('isLinuxOperatingSystem'), ',linux', ''))]",
        "siteResourceId": "[resourceId('Microsoft.Web/sites', parameters('siteName'))]",
        "sitesApiVersion": "2019-08-01",
        "sitesConfigApiVersion": "2019-08-01",
        "slots": "[if(variables('slotsIsNotEmpty'), parameters('slots'), json('[ { \"slotName\": \"DummySlot\" } ]'))]",
        "slotsCount": "[length(parameters('slots'))]",
        "slotsIsNotEmpty": "[greater(variables('slotsCount'), 0)]",
        "templateUriForMicrosoftKeyVaultAccessPolicies": "[uri(parameters('linkedTemplateBaseUri'), format('Items?path={0}{1}', uriComponent('/Microsoft.KeyVault/vaults-accessPolicies.json'), parameters('linkedTemplateQueryString')))]",
        "templateUriForMicrosoftWebSitesSlots": "[uri(parameters('linkedTemplateBaseUri'), format('Items?path={0}{1}', uriComponent('/Microsoft.Web/sites-slots.json'), parameters('linkedTemplateQueryString')))]",
        "virtualNetworkResourceGroupName": "[if(not(empty(coalesce(parameters('virtualNetworkResourceGroupName'), ''))), parameters('virtualNetworkResourceGroupName'), resourceGroup().name)]",
        "virtualNetworkResourceId": "[resourceId(variables('virtualNetworkResourceGroupName'), 'Microsoft.Network/virtualNetworks/subnets', parameters('virtualNetworkName'), parameters('subnetName'))]"
    },
    "resources": [
        {
            "apiVersion": "[variables('sitesApiVersion')]",
            "condition": "[parameters('isProductionSlotDeploymentEnabled')]",
            "kind": "[variables('siteKind')]",
            "identity": {
                "type": "SystemAssigned"
            },
            "location": "[parameters('location')]",
            "name": "[parameters('siteName')]",
            "properties": {
                "clientAffinityEnabled": "[parameters('isClientAffinityEnabled')]",
                "serverFarmId": "[variables('servicePlanResourceId')]",
                "siteConfig": "[variables('siteConfigForRoot')]"
            },
            "tags": "[parameters('tags')]",
            "type": "Microsoft.Web/sites"
        },
        {
            "apiVersion": "[variables('sitesConfigApiVersion')]",
            "condition": "[parameters('isProductionSlotDeploymentEnabled')]",
            "dependsOn": [
                "[variables('siteResourceId')]"
            ],
            "name": "[format('{0}/slotConfigNames', parameters('siteName'))]",
            "properties": {
                "appSettingNames": "[skip(variables('applicationSettingsSlotNames'), 1)]",
                "connectionStringNames": "[skip(variables('connectionStringsSlotNames'), 1)]"
            },
            "type": "Microsoft.Web/sites/config"
        },
        {
            "apiVersion": "[variables('sitesConfigApiVersion')]",
            "condition": "[and(parameters('isProductionSlotDeploymentEnabled'), variables('isVirtualNetworkIntegrationEnabled'))]",
            "dependsOn": [
                "[variables('siteResourceId')]"
            ],
            "name": "[format('{0}/virtualNetwork', parameters('siteName'))]",
            "properties": "[variables('siteConfigForVirtualNetworkProperties')]",
            "type": "Microsoft.Web/sites/config"
        },
        {
            "apiVersion": "[variables('sitesConfigApiVersion')]",
            "condition": "[parameters('isProductionSlotDeploymentEnabled')]",
            "dependsOn": [
                "[variables('siteResourceId')]"
            ],
            "name": "[format('{0}/web', parameters('siteName'))]",
            "properties": "[variables('siteConfigForWebProperties')]",
            "type": "Microsoft.Web/sites/config"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "condition": "[and(parameters('isProductionSlotDeploymentEnabled'), variables('keyVaultPermissionsIsNotEmpty'))]",
            "copy": {
                "count": "[variables('keyVaultPermissionsCount')]",
                "mode": "parallel",
                "name": "keyVaultAccessPoliciesCopy"
            },
            "dependsOn": [
                "[variables('siteResourceId')]"
            ],
            "name": "[format('{0}-kvap_{1}', deployment().name, copyIndex())]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "actionType": {
                        "value": "add"
                    },
                    "keyVaultName": {
                        "value": "[variables('keyVaultPermissions')[copyIndex()].keyVaultName]"
                    },
                    "objectId": {
                        "value": "[reference(variables('siteResourceId'), variables('sitesApiVersion'), 'Full').identity.principalId]"
                    },
                    "permissions": {
                        "value": "[variables('keyVaultPermissions')[copyIndex()].permissions]"
                    },
                    "tenantId": {
                        "value": "[reference(variables('siteResourceId'), variables('sitesApiVersion'), 'Full').identity.tenantId]"
                    }
                },
                "templateLink": {
                    "contentVersion": "2.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftKeyVaultAccessPolicies')]"
                }
            },
            "resourceGroup": "[union(json(format('{{ \"resourceGroupName\": \"{0}\" }}', resourceGroup().name)), variables('keyVaultPermissions')[copyIndex()]).resourceGroupName]",
            "subscriptionId": "[union(json(format('{{ \"subscriptionId\": \"{0}\" }}', subscription().subscriptionId)), variables('keyVaultPermissions')[copyIndex()]).subscriptionId]",
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "condition": "[variables('slotsIsNotEmpty')]",
            "copy": {
                "count": "[variables('slotsCount')]",
                "mode": "parallel",
                "name": "slotsCopy"
            },
            "dependsOn": [
                "[variables('siteResourceId')]"
            ],
            "name": "[format('{0}-slot_{1}', deployment().name, copyIndex())]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "applicationSettings": {
                        "value": "[union(json('{ \"applicationSettings\": [] }'), variables('slots')[copyIndex()]).applicationSettings]"
                    },
                    "connectionStrings": {
                        "value": "[union(json('{ \"connectionStrings\": [] }'), variables('slots')[copyIndex()]).connectionStrings]"
                    },
                    "functionVersion": {
                        "value": "[union(json('{ \"functionVersion\": \"~3\" }'), variables('slots')[copyIndex()]).functionVersion]"
                    },
                    "isAlwaysOnEnabled": {
                        "value": "[union(json('{ \"isAlwaysOnEnabled\": true }'), variables('slots')[copyIndex()]).isAlwaysOnEnabled]"
                    },
                    "isClientAffinityEnabled": {
                        "value": "[union(json('{ \"isClientAffinityEnabled\": false }'), variables('slots')[copyIndex()]).isClientAffinityEnabled]"
                    },
                    "isWebSocketsEnabled": {
                        "value": "[union(json('{ \"isWebSocketsEnabled\": true }'), variables('slots')[copyIndex()]).isWebSocketsEnabled]"
                    },
                    "is32BitModeEnabled": {
                        "value": "[union(json('{ \"is32BitModeEnabled\": false }'), variables('slots')[copyIndex()]).is32BitModeEnabled]"
                    },
                    "keyVaultPermissions": {
                        "value": "[union(json('{ \"keyVaultPermissions\": [] }'), variables('slots')[copyIndex()]).keyVaultPermissions]"
                    },
                    "kind": {
                        "value": "[union(json('{ \"kind\": \"app\" }'), variables('slots')[copyIndex()]).kind]"
                    },
                    "linkedTemplateBaseUri": {
                        "value": "[parameters('linkedTemplateBaseUri')]"
                    },
                    "linkedTemplateQueryString": {
                        "value": "[parameters('linkedTemplateQueryString')]"
                    },
                    "location": {
                        "value": "[parameters('location')]"
                    },
                    "operatingSystemName": {
                        "value": "[parameters('operatingSystemName')]"
                    },
                    "servicePlanName": {
                        "value": "[union(json(format('{{ \"servicePlanName\": \"{0}\" }}', parameters('servicePlanName'))), variables('slots')[copyIndex()]).servicePlanName]"
                    },
                    "servicePlanResourceGroupName": {
                        "value": "[union(json(format('{{ \"servicePlanResourceGroupName\": \"{0}\" }}', resourceGroup().name)), variables('slots')[copyIndex()]).servicePlanResourceGroupName]"
                    },
                    "siteName": {
                        "value": "[parameters('siteName')]"
                    },
                    "slotName": {
                        "value": "[variables('slots')[copyIndex()].slotName]"
                    },
                    "stack": {
                        "value": "[union(json('{ \"stack\": \"dotnetcore\" }'), variables('slots')[copyIndex()]).stack]"
                    },
                    "subnetName": {
                        "value": "[union(json('{ \"subnetName\": \"\" }'), variables('slots')[copyIndex()]).subnetName]"
                    },
                    "tags": {
                        "value": "[parameters('tags')]"
                    },
                    "virtualNetworkName": {
                        "value": "[union(json('{ \"virtualNetworkName\": \"\" }'), variables('slots')[copyIndex()]).virtualNetworkName]"
                    },
                    "virtualNetworkResourceGroupName": {
                        "value": "[union(json('{ \"virtualNetworkResourceGroupName\": \"\" }'), variables('slots')[copyIndex()]).virtualNetworkResourceGroupName]"
                    }
                },
                "templateLink": {
                    "contentVersion": "2.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftWebSitesSlots')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        }
    ],
    "outputs": {
        "siteIdentity": {
            "type": "object",
            "value": "[reference(variables('siteResourceId'), variables('sitesApiVersion'), 'Full').identity]"
        },
        "slotIdentities": {
            "copy": {
                "count": "[variables('slotsCount')]",
                "input": {
                    "identity": "[reference(format('{0}-slot_{1}', deployment().name, copyIndex())).outputs.identity.value]",
                    "slotName": "[variables('slots')[copyIndex()].slotName]"
                }
            },
            "type": "array"
        }
    }
}
