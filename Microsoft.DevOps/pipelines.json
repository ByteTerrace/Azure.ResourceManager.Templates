{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Specifies the location in which the Azure DevOps Pipeline resource(s) will be deployed."
            },
            "type": "string"
        },
        "name": {
            "metadata": {
                "description": "Specifies the name of the Azure DevOps Pipeline."
            },
            "type": "string"
        },
        "tags": {
            "defaultValue": {},
            "metadata": {
                "description": "Specifies the set of tag key-value pairs that will be assigned to the Azure DevOps Pipeline."
            },
            "type": "object"
        }
    },
    "resources": [
        {
            "apiVersion": "2019-07-01-preview",
            "location": "[parameters('location')]",
            "name": "[parameters('name')]",
            "properties": {},
            "tags": "[parameters('tags')]",
            "type": "Microsoft.DevOps/pipelines"
        }
    ]
}
