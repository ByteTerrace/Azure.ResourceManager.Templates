{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "isBgpRoutePropagationEnabled": {
            "defaultValue": false,
            "metadata": {
                "description": "Indicates whether the BGP route propagation feature is enabled on the Azure Route Table."
            },
            "type": "bool"
        },
        "location": {
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Specifies the location in which the Azure Route Table resource(s) will be deployed."
            },
            "type": "string"
        },
        "name": {
            "maxLength": 80,
            "metadata": {
                "description": "Specifies the name of the Azure Route Table."
            },
            "minLength": 1,
            "type": "string"
        },
        "routes": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of routes that will be created within the Azure Route Table."
            },
            "type": "array"
        },
        "tags": {
            "defaultValue": {},
            "metadata": {
                "description": "Specifies the set of tag key-value pairs that will be assigned to the public Azure Route Table."
            },
            "type": "object"
        }
    },
    "variables": {},
    "resources": [
        {
            "apiVersion": "2020-07-01",
            "location": "[parameters('location')]",
            "name": "[parameters('name')]",
            "properties": {
                "disableBgpRoutePropagation": "[parameters('isBgpRoutePropagationEnabled')]",
                "routes": "[parameters('routes')]"
            },
            "tags": "[parameters('tags')]",
            "type": "Microsoft.Network/routeTables"
        }
    ]
}
