{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "name": {
            "maxLength": 63,
            "metadata": {
                "description": "Specifies the name of the Azure DNS zone."
            },
            "minLength": 1,
            "type": "string"
        },
        "tags": {
            "defaultValue": {},
            "metadata": {
                "description": "Specifies the set of tag key-value pairs that will be assigned to the Azure DNS zone."
            },
            "type": "object"
        },
        "type": {
            "defaultValue": "Public",
            "metadata": {
                "description": "Specifies the type of the Azure DNS zone."
            },
            "type": "string"
        }
    },
    "resources": [
        {
            "apiVersion": "2018-05-01",
            "location": "global",
            "name": "[parameters('name')]",
            "properties": {
                "registrationVirtualNetworks": [],
                "resolutionVirtualNetworks": [],
                "zoneType": "[parameters('type')]"
            },
            "tags": "[parameters('tags')]",
            "type": "Microsoft.Network/dnsZones"
        }
    ]
}
