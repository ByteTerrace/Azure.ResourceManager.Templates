{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "accessTier": {
            "defaultValue": "Hot",
            "metadata": {
                "description": "Specifies the access tier of the Azure Storage account."
            },
            "type": "string"
        },
        "blobContainerNames": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of blob container names that should be deployed within the Azure Storage account."
            },
            "type": "array"
        },
        "customerManagedEncryptionKeyName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the name of the customer-managed data encryption key."
            },
            "type": "string"
        },
        "customerManagedEncryptionKeyVaultName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the name of the key vault that houses the customer-managed data encryption key."
            },
            "type": "string"
        },
        "customerManagedEncryptionKeyVaultResourceGroupName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the resource group name of the key vault that houses the customer-managed data encryption key."
            },
            "type": "string"
        },
        "customerManagedEncryptionKeyVaultSubscriptionId": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the subscrioption id of the key vault that houses the customer-managed data encryption key."
            },
            "type": "string"
        },
        "customerManagedEncryptionKeyVersion": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the version of the customer-managed data encryption key."
            },
            "type": "string"
        },
        "encryptionScopes": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of encryption scopes that should be assigned the Azure Storage account."
            },
            "type": "array"
        },
        "fileShareNames": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of file share names that should be deployed within the Azure Storage account."
            },
            "type": "array"
        },
        "firewallRules": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of firewall rules that will be assigned to the Azure Storage account."
            },
            "type": "array"
        },
        "isAllowTrustedMicrosoftServicesEnabled": {
            "defaultValue": false,
            "metadata": {
                "description": "Indicates whether trusted Microsoft services are allowed to access the Azure Storage account."
            },
            "type": "bool"
        },
        "isHierarchicalNamespaceEnabled": {
            "defaultValue": false,
            "metadata": {
                "description": "Indicates whether the hierarchical namespace feature is enabled on the Azure Storage account."
            },
            "type": "bool"
        },
        "isLargeFileSharesEnabled": {
            "defaultValue": false,
            "metadata": {
                "description": "Indicates whether the large file shares feature is enabled on the Azure Storage account."
            },
            "type": "bool"
        },
        "linkedTemplateBaseUri": {
            "defaultValue": "https://dev.azure.com/ByteTerrace/Azure/_apis/git/repositories/Azure.ResourceManager.Templates/",
            "metadata": {
                "description": "Specifies the base uri of external linked templates used by this template."
            },
            "type": "string"
        },
        "linkedTemplateQueryString": {
            "defaultValue": "&recursionLevel=0&versionDescriptor.version=master&versionDescriptor.versionOptions=0&versionDescriptor.versionType=0&includeContent=true&resolveLfs=true",
            "metadata": {
                "description": "Specifies the query string that will be appended to the uri of external linked templates used by this template."
            },
            "type": "string"
        },
        "location": {
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Specifies the location in which the Azure Storage resource(s) should be deployed."
            },
            "type": "string"
        },
        "skuName": {
            "allowedValues": [
                "Premium_LRS",
                "Premium_ZRS",
                "Standard_GRS",
                "Standard_GZRS",
                "Standard_LRS",
                "Standard_RAGRS",
                "Standard_RAGZRS",
                "Standard_ZRS"
            ],
            "defaultValue": "Standard_LRS",
            "metadata": {
                "description": "Specifies the SKU name of the Azure Storage account."
            },
            "type": "string"
        },
        "storageAccountKind": {
            "allowedValues": [
                "StorageV2"
            ],
            "defaultValue": "StorageV2",
            "metadata": {
                "description": "Specifies the kind of the Azure Storage account."
            },
            "type": "string"
        },
        "storageAccountName": {
            "maxLength": 24,
            "metadata": {
                "description": "Specifies the name of the Azure Storage account."
            },
            "minLength": 3,
            "type": "string"
        },
        "tags": {
            "defaultValue": {},
            "metadata": {
                "description": "Specifies the set of tag key-value pairs that will be assigned to the Azure Storage account."
            },
            "type": "object"
        },
        "virtualNetworkRules": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of virtual network rules that will be assigned to the Azure Storage account."
            },
            "type": "array"
        }
    },
    "variables": {
        "blobContainerApiVersion": "2019-06-01",
        "blobContainerNames": "[if(variables('blobContainerNamesIsNotEmpty'), parameters('blobContainerNames'), json('[ \"dummyContainer\" ]'))]",
        "blobContainerNamesCount": "[length(parameters('blobContainerNames'))]",
        "blobContainerNamesIsNotEmpty": "[greater(variables('blobContainerNamesCount'), 0)]",
        "customerManagedEncryptionAccessPolicyDeploymentName": "[format('{0}-{1}-CmeAccessPolicy', deployment().name, variables('storageAccountName'))]",
        "customerManagedEncryptionAccessPolicyDeploymentResourceId": "[resourceId(variables('customerManagedEncryptionKeyVaultSubscriptionId'), variables('customerManagedEncryptionKeyVaultResourceGroupName'), 'Microsoft.Resources/deployments', variables('customerManagedEncryptionAccessPolicyDeploymentName'))]",
        "customerManagedEncryptionPropertiesDeploymentName": "[format('{0}-{1}-CmeProperties', deployment().name, variables('storageAccountName'))]",
        "customerManagedEncryptionPropertiesDeploymentResourceId": "[resourceId('Microsoft.Resources/deployments', variables('customerManagedEncryptionPropertiesDeploymentName'))]",
        "customerManagedEncryptionIsEnabled": "[and(variables('customerManagedEncryptionKeyNameIsNotNullOrEmpty'), variables('customerManagedEncryptionKeyVaultNameIsNotNullOrEmpty'))]",
        "customerManagedEncryptionKeyNameIsNotNullOrEmpty": "[not(empty(coalesce(parameters('customerManagedEncryptionKeyName'), '')))]",
        "customerManagedEncryptionKeyVaultNameIsNotNullOrEmpty": "[not(empty(coalesce(parameters('customerManagedEncryptionKeyVaultName'), '')))]",
        "customerManagedEncryptionKeyVaultResourceGroupName": "[if(variables('customerManagedEncryptionKeyVaultResourceGroupNameIsNotNullOrEmpty'), parameters('customerManagedEncryptionKeyVaultResourceGroupName'), resourceGroup().name)]",
        "customerManagedEncryptionKeyVaultResourceGroupNameIsNotNullOrEmpty": "[not(empty(coalesce(parameters('customerManagedEncryptionKeyVaultResourceGroupName'), '')))]",
        "customerManagedEncryptionKeyVaultResourceId": "[resourceId(variables('customerManagedEncryptionKeyVaultSubscriptionId'), variables('customerManagedEncryptionKeyVaultResourceGroupName'), 'Microsoft.KeyVault/vaults', parameters('customerManagedEncryptionKeyVaultName'))]",
        "customerManagedEncryptionKeyVaultSubscriptionId": "[if(variables('customerManagedEncryptionKeyVaultSubscriptionIdIsNotNullOrEmpty'), parameters('customerManagedEncryptionKeyVaultSubscriptionId'), subscription().subscriptionId)]",
        "customerManagedEncryptionKeyVaultSubscriptionIdIsNotNullOrEmpty": "[not(empty(coalesce(parameters('customerManagedEncryptionKeyVaultSubscriptionId'), '')))]",
        "customerManagedEncryptionKeyVersionNameIsNotNullOrEmpty": "[not(empty(coalesce(parameters('customerManagedEncryptionKeyVersion'), '')))]",
        "deploymentApiVersion": "2019-10-01",
        "encryptionScopeVersion": "2019-06-01",
        "encryptionScopes": "[if(variables('encryptionScopesIsNotEmpty'), parameters('encryptionScopes'), json('[ { \"keyVaultName\": \"dummyKeyVault\" } ]'))]",
        "encryptionScopesCount": "[length(parameters('encryptionScopes'))]",
        "encryptionScopesIsNotEmpty": "[greater(variables('encryptionScopesCount'), 0)]",
        "fileShareApiVersion": "2019-06-01",
        "fileShareNames": "[if(variables('fileShareNamesIsNotEmpty'), parameters('fileShareNames'), json('[ \"dummyFileShare\" ]'))]",
        "fileShareNamesCount": "[length(parameters('fileShareNames'))]",
        "fileShareNamesIsNotEmpty": "[greater(variables('fileShareNamesCount'), 0)]",
        "keyVaultApiVersion": "2019-09-01",
        "storageAccountApiVersion": "2019-06-01",
        "storageAccountName": "[toLower(parameters('storageAccountName'))]",
        "storageAccountResourceId": "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]",
        "templateUriForMicrosoftKeyVaultAccessPolicies": "[uri(parameters('linkedTemplateBaseUri'), format('Items?path={0}{1}', uriComponent('/Microsoft.KeyVault/vaults/Microsoft.KeyVault-vaults-accessPolicies.json'), parameters('linkedTemplateQueryString')))]"
    },
    "resources": [
        {
            "apiVersion": "[variables('storageAccountApiVersion')]",
            "identity": {
                "type": "SystemAssigned"
            },
            "kind": "[parameters('storageAccountKind')]",
            "location": "[parameters('location')]",
            "name": "[variables('storageAccountName')]",
            "properties": {
                "accessTier": "[parameters('accessTier')]",
                "isHnsEnabled": "[parameters('isHierarchicalNamespaceEnabled')]",
                "largeFileSharesState": "[if(parameters('isLargeFileSharesEnabled'), 'Enabled', 'Disabled')]",
                "networkAcls": {
                    "bypass": "[if(parameters('isAllowTrustedMicrosoftServicesEnabled'), 'AzureServices', 'None')]",
                    "copy": [
                        {
                            "count": "[length(parameters('firewallRules'))]",
                            "input": {
                                "action": "Allow",
                                "value": "[parameters('firewallRules')[copyIndex('ipRules')]]"
                            },
                            "name": "ipRules"
                        },
                        {
                            "count": "[length(parameters('virtualNetworkRules'))]",
                            "input": {
                                "action": "Allow",
                                "id": "[resourceId(union(json(format('{{ \"subscriptionId\": \"{0}\" }}', subscription().subscriptionId)), parameters('virtualNetworkRules')[copyIndex('virtualNetworkRules')]).subscriptionId, union(json(format('{{ \"resourceGroupName\": \"{0}\" }}', resourceGroup().name)), parameters('virtualNetworkRules')[copyIndex('virtualNetworkRules')]).resourceGroupName, 'Microsoft.Network/virtualNetworks/subnets', parameters('virtualNetworkRules')[copyIndex('virtualNetworkRules')].virtualNetworkName, parameters('virtualNetworkRules')[copyIndex('virtualNetworkRules')].subnetName)]"
                            },
                            "name": "virtualNetworkRules"
                        }
                    ],
                    "defaultAction": "Deny"
                },
                "supportsHttpsTrafficOnly": true
            },
            "sku": {
                "name": "[parameters('skuName')]"
            },
            "tags": "[parameters('tags')]",
            "type": "Microsoft.Storage/storageAccounts"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "condition": "[variables('customerManagedEncryptionIsEnabled')]",
            "dependsOn": [
                "[variables('storageAccountResourceId')]"
            ],
            "name": "[variables('customerManagedEncryptionAccessPolicyDeploymentName')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "actionType": {
                        "value": "add"
                    },
                    "keyVaultName": {
                        "value": "[parameters('customerManagedEncryptionKeyVaultName')]"
                    },
                    "objectId": {
                        "value": "[reference(variables('storageAccountResourceId'), variables('storageAccountApiVersion'), 'Full').identity.principalId]"
                    },
                    "permissions": {
                        "value": {
                            "keys": [
                                "get",
                                "unwrapKey",
                                "wrapkey"
                            ]
                        }
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftKeyVaultAccessPolicies')]"
                }
            },
            "resourceGroup": "[variables('customerManagedEncryptionKeyVaultResourceGroupName')]",
            "subscriptionId": "[variables('customerManagedEncryptionKeyVaultSubscriptionId')]",
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "condition": "[variables('customerManagedEncryptionIsEnabled')]",
            "dependsOn": [
                "[variables('customerManagedEncryptionAccessPolicyDeploymentResourceId')]",
                "[variables('storageAccountResourceId')]"
            ],
            "name": "[variables('customerManagedEncryptionPropertiesDeploymentName')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {},
                "template": {
                    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
                    "contentVersion": "1.0.0.0",
                    "resources": [
                        {
                            "apiVersion": "[variables('storageAccountApiVersion')]",
                            "kind": "[parameters('storageAccountKind')]",
                            "location": "[parameters('location')]",
                            "name": "[variables('storageAccountName')]",
                            "properties": {
                                "encryption": {
                                    "keyvaultproperties": {
                                        "keyname": "[parameters('customerManagedEncryptionKeyName')]",
                                        "keyvaulturi": "[if(variables('customerManagedEncryptionIsEnabled'), take(reference(variables('customerManagedEncryptionKeyVaultResourceId'), variables('keyVaultApiVersion')).vaultUri, sub(length(reference(variables('customerManagedEncryptionKeyVaultResourceId'), variables('keyVaultApiVersion')).vaultUri), 1)), json('null'))]",
                                        "keyversion": "[if(variables('customerManagedEncryptionKeyVersionNameIsNotNullOrEmpty'), parameters('customerManagedEncryptionKeyVersion'), json('null'))]"
                                    },
                                    "services": {
                                        "blob": {
                                            "enabled": true,
                                            "keyType": "Account"
                                        },
                                        "file": {
                                            "enabled": true,
                                            "keyType": "Account"
                                        }
                                    },
                                    "keySource": "Microsoft.Keyvault"
                                }
                            },
                            "sku": {
                                "name": "[parameters('skuName')]"
                            },
                            "type": "Microsoft.Storage/storageAccounts"
                        }
                    ]
                }
            },
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('encryptionScopeVersion')]",
            "condition": "[variables('encryptionScopesIsNotEmpty')]",
            "copy": {
                "count": "[variables('encryptionScopesCount')]",
                "mode": "parallel",
                "name": "encryptionScopesCopy"
            },
            "dependsOn": [
                "[variables('customerManagedEncryptionPropertiesDeploymentResourceId')]",
                "[variables('storageAccountResourceId')]"
            ],
            "name": "[format('{0}/{1}', variables('storageAccountName'), union(json(format('{{ \"encryptionScopeName\": \"encryptionScope{0}\"}}', copyIndex())), variables('encryptionScopes')[copyIndex()]).encryptionScopeName)]",
            "properties": {
                "keyVaultProperties": {
                    "keyUri": "[if(variables('encryptionScopesIsNotEmpty'), format('{0}keys/{1}', reference(resourceId(union(json(format('{{ \"subscriptionId\": \"{0}\" }}', subscription().subscriptionId)), variables('encryptionScopes')[copyIndex()]).subscriptionId, variables('encryptionScopes')[copyIndex()].resourceGroupName, 'Microsoft.KeyVault/vaults', variables('encryptionScopes')[copyIndex()].keyVaultName), variables('keyVaultApiVersion')).vaultUri, variables('encryptionScopes')[copyIndex()].keyName), json('null'))]"
                },
                "source": "Microsoft.KeyVault",
                "state": "Enabled"
            },
            "type": "Microsoft.Storage/storageAccounts/encryptionScopes"
        },
        {
            "apiVersion": "[variables('blobContainerApiVersion')]",
            "condition": "[variables('blobContainerNamesIsNotEmpty')]",
            "copy": {
                "count": "[variables('blobContainerNamesCount')]",
                "mode": "parallel",
                "name": "blobContainerCopy"
            },
            "dependsOn": [
                "[variables('customerManagedEncryptionPropertiesDeploymentResourceId')]",
                "[variables('storageAccountResourceId')]"
            ],
            "name": "[format('{0}/default/{1}', variables('storageAccountName'), variables('blobContainerNames')[copyIndex()])]",
            "type": "Microsoft.Storage/storageAccounts/blobServices/containers"
        },
        {
            "apiVersion": "[variables('fileShareApiVersion')]",
            "condition": "[variables('fileShareNamesIsNotEmpty')]",
            "copy": {
                "count": "[variables('fileShareNamesCount')]",
                "mode": "parallel",
                "name": "fileShareCopy"
            },
            "dependsOn": [
                "[variables('customerManagedEncryptionPropertiesDeploymentResourceId')]",
                "[variables('storageAccountResourceId')]"
            ],
            "name": "[format('{0}/default/{1}', variables('storageAccountName'), variables('fileShareNames')[copyIndex()])]",
            "type": "Microsoft.Storage/storageAccounts/fileServices/shares"
        }
    ]
}
