{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "applicationName": {
            "defaultValue": "DeleteMePlz",
            "type": "string"
        },
        "clientIpAddress": {
            "type": "string"
        }
    },
    "variables": {
        "deploymentApiVersion": "2019-10-01",
        "deploymentNameForMicrosoftAppConfiguration": "[format('{0}-AppConfiguration', deployment().name)]",
        "deploymentNameForMicrosoftKeyVault": "[format('{0}-KeyVault', deployment().name)]",
        "deploymentNameForMicrosoftSqlServer": "[format('{0}-MsSqlServer', deployment().name)]",
        "deploymentNameForMicrosoftStorageAccount": "[format('{0}-StorageAccount', deployment().name)]",
        "deploymentNameForMicrosoftVirtualNetwork": "[format('{0}-VirtualNetwork', deployment().name)]",
        "deploymentNameForMicrosoftWebAppServerFarm": "[format('{0}-WebAppServerFarm', deployment().name)]",
        "templateUriForMicrosoftAppConfiguration": "https://dev.azure.com/ByteTerrace/Azure/_apis/git/repositories/Azure.ResourceManager.Templates/Items?path=%2FMicrosoft.AppConfiguration%2FconfigurationStores%2FMicrosoft.AppConfiguration-configurationStores.json&recursionLevel=0&versionDescriptor.version=master&versionDescriptor.versionOptions=0&versionDescriptor.versionType=0&includeContent=true&resolveLfs=true",
        "templateUriForKeyVault": "https://dev.azure.com/ByteTerrace/Azure/_apis/git/repositories/Azure.ResourceManager.Templates/Items?path=%2FMicrosoft.KeyVault%2Fvaults%2FMicrosoft.KeyVault-vaults.json&recursionLevel=0&versionDescriptor.version=master&versionDescriptor.versionOptions=0&versionDescriptor.versionType=0&includeContent=true&resolveLfs=true",
        "templateUriForMicrosoftSqlServer": "https://dev.azure.com/ByteTerrace/Azure/_apis/git/repositories/Azure.ResourceManager.Templates/Items?path=%2FMicrosoft.Sql%2Fservers%2FMicrosoft.Sql-servers.json&recursionLevel=0&versionDescriptor.version=master&versionDescriptor.versionOptions=0&versionDescriptor.versionType=0&includeContent=true&resolveLfs=true",
        "templateUriForMicrosoftStorageAccount": "https://dev.azure.com/ByteTerrace/Azure/_apis/git/repositories/Azure.ResourceManager.Templates/Items?path=%2FMicrosoft.Storage%2FstorageAccounts%2FMicrosoft.Storage-storageAccounts.json&recursionLevel=0&versionDescriptor.version=master&versionDescriptor.versionOptions=0&versionDescriptor.versionType=0&includeContent=true&resolveLfs=true",
        "templateUriForMicrosoftVirtualNetwork": "https://dev.azure.com/ByteTerrace/Azure/_apis/git/repositories/Azure.ResourceManager.Templates/Items?path=%2FMicrosoft.Network%2FvirtualNetworks%2FMicrosoft.Network-virtualNetworks.json&recursionLevel=0&versionDescriptor.version=master&versionDescriptor.versionOptions=0&versionDescriptor.versionType=0&includeContent=true&resolveLfs=true",
        "templateUriForMicrosoftWebAppServerFarm": "https://dev.azure.com/ByteTerrace/Azure/_apis/git/repositories/Azure.ResourceManager.Templates/Items?path=%2FMicrosoft.Web%2Fserverfarms%2FMicrosoft.Web-serverfarms.json&recursionLevel=0&versionDescriptor.version=master&versionDescriptor.versionOptions=0&versionDescriptor.versionType=0&includeContent=true&resolveLfs=true"
    },
    "resources": [
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "name": "[variables('deploymentNameForMicrosoftVirtualNetwork')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "subnets": {
                        "value": [
                            {
                                "name": "default",
                                "properties": {
                                    "addressPrefix": "10.0.0.0/24",
                                    "serviceEndpoints": [
                                        {
                                            "service": "Microsoft.KeyVault"
                                        },
                                        {
                                            "service": "Microsoft.Sql"
                                        },
                                        {
                                            "service": "Microsoft.Storage"
                                        }
                                    ]
                                }
                            }
                        ]
                    },
                    "virtualNetworkName": {
                        "value": "[format('{0}-VirtualNetwork', parameters('applicationName'))]"
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftVirtualNetwork')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "name": "[variables('deploymentNameForMicrosoftAppConfiguration')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "configurationStoreName": {
                        "value": "[format('{0}-AppConfig', parameters('applicationName'))]"
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftAppConfiguration')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "dependsOn": [
                "[variables('deploymentNameForMicrosoftVirtualNetwork')]"
            ],
            "name": "[variables('deploymentNameForMicrosoftStorageAccount')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "firewallRules": {
                        "value": [
                            "[parameters('clientIpAddress')]"
                        ]
                    },
                    "isAllowTrustedMicrosoftServicesEnabled": {
                        "value": true
                    },
                    "storageAccountName": {
                        "value": "[format('{0}storage', parameters('applicationName'))]"
                    },
                    "virtualNetworkRules": {
                        "value": [
                            {
                                "virtualNetworkName": "[format('{0}-VirtualNetwork', parameters('applicationName'))]",
                                "subnetName": "default"
                            }
                        ]
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftStorageAccount')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "dependsOn": [
                "[variables('deploymentNameForMicrosoftStorageAccount')]",
                "[variables('deploymentNameForMicrosoftVirtualNetwork')]"
            ],
            "name": "[variables('deploymentNameForMicrosoftKeyVault')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "firewallRules": {
                        "value": [
                            "[parameters('clientIpAddress')]"
                        ]
                    },
                    "keyVaultName": {
                        "value": "[format('{0}-KeyVault', parameters('applicationName'))]"
                    },
                    "virtualNetworkRules": {
                        "value": [
                            {
                                "virtualNetworkName": "[format('{0}-VirtualNetwork', parameters('applicationName'))]",
                                "subnetName": "default"
                            }
                        ]
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('templateUriForKeyVault')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "dependsOn": [
                "[variables('deploymentNameForMicrosoftKeyVault')]",
                "[variables('deploymentNameForMicrosoftStorageAccount')]",
                "[variables('deploymentNameForMicrosoftVirtualNetwork')]"
            ],
            "name": "[variables('deploymentNameForMicrosoftSqlServer')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "auditStorageAccountName": {
                        "value": "[format('{0}storage', parameters('applicationName'))]"
                    },
                    "databases": {
                        "value": [
                            {
                                "databaseName": "[parameters('applicationName')]"
                            }
                        ]
                    },
                    "firewallRules": {
                        "value": [
                            {
                                "endIpAddress": "[parameters('clientIpAddress')]",
                                "ruleName": "Temp",
                                "startIpAddress": "[parameters('clientIpAddress')]"
                            }
                        ]
                    },
                    "serverName": {
                        "value": "[parameters('applicationName')]"
                    },
                    "virtualNetworkRules": {
                        "value": [
                            {
                                "ruleName": "Temp",
                                "virtualNetworkName": "[format('{0}-VirtualNetwork', parameters('applicationName'))]",
                                "subnetName": "default"
                            }
                        ]
                    },
                    "vulnerabilityAssessmentStorageAccountName": {
                        "value": "[format('{0}storage', parameters('applicationName'))]"
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftSqlServer')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "dependsOn": [
                "[variables('deploymentNameForMicrosoftStorageAccount')]"
            ],
            "name": "[variables('deploymentNameForMicrosoftWebAppServerFarm')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "servicePlanName": {
                        "value": "[format('{0}-ASP', parameters('applicationName'))]"
                    },
                    "sites": {
                        "value": [
                            {
                                "isAlwaysOnEnabled": false,
                                "is32BitModeEnabled": true,
                                "siteName": "[parameters('applicationName')]"
                            }
                        ]
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftWebAppServerFarm')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        }
    ]
}
