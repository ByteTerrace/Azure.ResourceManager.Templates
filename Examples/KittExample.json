{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "functions": [
        {
            "namespace": "byteterrace",
            "members": {
                "templateUri": {
                    "parameters": [
                        {
                            "name": "baseUri",
                            "type": "string"
                        },
                        {
                            "name": "path",
                            "type": "string"
                        },
                        {
                            "name": "queryString",
                            "type": "string"
                        }
                    ],
                    "output": {
                        "type": "string",
                        "value": "[uri(parameters('baseUri'), format('Items?path={0}{1}', uriComponent(parameters('path')), parameters('queryString')))]"
                    }
                }
            }
        }
    ],
    "parameters": {
        "applicationName": {
            "defaultValue": "KittExample",
            "type": "string"
        },
        "clientIpAddress": {
            "type": "string"
        },
        "templateBaseUri": {
            "defaultValue": "https://dev.azure.com/ByteTerrace/Azure/_apis/git/repositories/Azure.ResourceManager.Templates/",
            "type": "string"
        },
        "templateQueryString": {
            "defaultValue": "&recursionLevel=0&versionDescriptor.version=master&versionDescriptor.versionOptions=0&versionDescriptor.versionType=0&includeContent=true&resolveLfs=true",
            "type": "string"
        }
    },
    "variables": {
        "deploymentApiVersion": "2019-10-01",
        "deploymentNameForMicrosoftAppConfiguration": "[format('{0}-AppConfiguration', deployment().name)]",
        "deploymentNameForMicrosoftKeyVault": "[format('{0}-KeyVault', deployment().name)]",
        "deploymentNameForMicrosoftSqlServer": "[format('{0}-MsSqlServer', deployment().name)]",
        "deploymentNameForMicrosoftStorageAccount": "[format('{0}-StorageAccount', deployment().name)]",
        "deploymentNameForMicrosoftVirtualNetwork": "[format('{0}-VirtualNetwork', deployment().name)]",
        "deploymentNameForMicrosoftWebAppServerFarm": "[format('{0}-WebAppServerFarm', deployment().name)]",
        "templateUriForMicrosoftAppConfiguration": "[byteterrace.templateUri(parameters('templateBaseUri'), '/Microsoft.AppConfiguration/configurationStores/Microsoft.AppConfiguration-configurationStores.json', parameters('templateQueryString'))]",
        "templateUriForMicrosoftKeyVault": "[byteterrace.templateUri(parameters('templateBaseUri'), '/Microsoft.KeyVault/vaults/Microsoft.KeyVault-vaults.json', parameters('templateQueryString'))]",
        "templateUriForMicrosoftSqlServer": "[byteterrace.templateUri(parameters('templateBaseUri'), '/Microsoft.Sql/servers/Microsoft.Sql-servers.json', parameters('templateQueryString'))]",
        "templateUriForMicrosoftStorageAccount": "[byteterrace.templateUri(parameters('templateBaseUri'), '/Microsoft.Storage/storageAccounts/Microsoft.Storage-storageAccounts.json', parameters('templateQueryString'))]",
        "templateUriForMicrosoftVirtualNetwork": "[byteterrace.templateUri(parameters('templateBaseUri'), '/Microsoft.Network/virtualNetworks/Microsoft.Network-virtualNetworks.json', parameters('templateQueryString'))]",
        "templateUriForMicrosoftWebAppServerFarm": "[byteterrace.templateUri(parameters('templateBaseUri'), '/Microsoft.Web/serverfarms/Microsoft.Web-serverfarms.json', parameters('templateQueryString'))]",
        "sqlServerSettings": {
            "serverName": "[format('{0}-Sql', parameters('applicationName'))]"
        },
        "virtualNetworkSettings": {
            "subnets": [
                {
                    "name": "default",
                    "properties": {
                        "addressPrefix": "10.0.0.0/24",
                        "delegations": [
                            {
                                "name": "delegation",
                                "properties": {
                                    "serviceName": "Microsoft.Web/serverfarms"
                                }
                            }
                        ],
                        "serviceEndpoints": [
                            {
                                "service": "Microsoft.KeyVault"
                            },
                            {
                                "service": "Microsoft.Sql"
                            },
                            {
                                "service": "Microsoft.Storage"
                            },
                            {
                                "service": "Microsoft.Web"
                            }
                        ]
                    }
                }
            ],
            "virtualNetworkName": "[format('{0}-Vnet', parameters('applicationName'))]"
        }
    },
    "resources": [
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "name": "[variables('deploymentNameForMicrosoftVirtualNetwork')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "subnets": {
                        "value": "[variables('virtualNetworkSettings').subnets]"
                    },
                    "virtualNetworkName": {
                        "value": "[variables('virtualNetworkSettings').virtualNetworkName]"
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftVirtualNetwork')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "name": "[variables('deploymentNameForMicrosoftAppConfiguration')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "configurationStoreName": {
                        "value": "[format('{0}-AppConfig', parameters('applicationName'))]"
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftAppConfiguration')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "dependsOn": [
                "[variables('deploymentNameForMicrosoftVirtualNetwork')]"
            ],
            "name": "[variables('deploymentNameForMicrosoftStorageAccount')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "firewallRules": {
                        "value": [
                            "[parameters('clientIpAddress')]"
                        ]
                    },
                    "isAllowTrustedMicrosoftServicesEnabled": {
                        "value": true
                    },
                    "storageAccountName": {
                        "value": "[format('{0}storage', parameters('applicationName'))]"
                    },
                    "virtualNetworkRules": {
                        "value": [
                            {
                                "subnetName": "default",
                                "virtualNetworkName": "[variables('virtualNetworkSettings').virtualNetworkName]"
                            }
                        ]
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftStorageAccount')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "dependsOn": [
                "[variables('deploymentNameForMicrosoftStorageAccount')]",
                "[variables('deploymentNameForMicrosoftVirtualNetwork')]"
            ],
            "name": "[variables('deploymentNameForMicrosoftKeyVault')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "auditStorageAccountName": {
                        "value": "[format('{0}storage', parameters('applicationName'))]"
                    },
                    "firewallRules": {
                        "value": [
                            "[parameters('clientIpAddress')]"
                        ]
                    },
                    "isAllowTrustedMicrosoftServicesEnabled": {
                        "value": true
                    },
                    "keyVaultName": {
                        "value": "[format('{0}-KeyVault', parameters('applicationName'))]"
                    },
                    "virtualNetworkRules": {
                        "value": [
                            {
                                "subnetName": "default",
                                "virtualNetworkName": "[variables('virtualNetworkSettings').virtualNetworkName]"
                            }
                        ]
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftKeyVault')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "dependsOn": [
                "[variables('deploymentNameForMicrosoftKeyVault')]",
                "[variables('deploymentNameForMicrosoftStorageAccount')]",
                "[variables('deploymentNameForMicrosoftVirtualNetwork')]"
            ],
            "name": "[variables('deploymentNameForMicrosoftSqlServer')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "auditStorageAccountName": {
                        "value": "[format('{0}storage', parameters('applicationName'))]"
                    },
                    "databases": {
                        "value": [
                            {
                                "databaseName": "[parameters('applicationName')]"
                            }
                        ]
                    },
                    "firewallRules": {
                        "value": [
                            {
                                "endIpAddress": "[parameters('clientIpAddress')]",
                                "ruleName": "Temp",
                                "startIpAddress": "[parameters('clientIpAddress')]"
                            }
                        ]
                    },
                    "serverName": {
                        "value": "[variables('sqlServerSettings').serverName]"
                    },
                    "virtualNetworkRules": {
                        "value": [
                            {
                                "ruleName": "Temp",
                                "subnetName": "default",
                                "virtualNetworkName": "[variables('virtualNetworkSettings').virtualNetworkName]"
                            }
                        ]
                    },
                    "vulnerabilityAssessmentStorageAccountName": {
                        "value": "[format('{0}storage', parameters('applicationName'))]"
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftSqlServer')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "dependsOn": [
                "[variables('deploymentNameForMicrosoftStorageAccount')]",
                "[variables('deploymentNameForMicrosoftVirtualNetwork')]"
            ],
            "name": "[variables('deploymentNameForMicrosoftWebAppServerFarm')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "servicePlanName": {
                        "value": "[format('{0}-Portal-ASP', parameters('applicationName'))]"
                    },
                    "sites": {
                        "value": [
                            {
                                "applicationSettings": [
                                    {
                                        "isSlotSetting": true,
                                        "name": "A",
                                        "value": "0"
                                    },
                                    {
                                        "isSlotSetting": false,
                                        "name": "B",
                                        "value": "1"
                                    },
                                    {
                                        "isSlotSetting": true,
                                        "name": "C",
                                        "value": "2"
                                    }
                                ],
                                "isAlwaysOnEnabled": true,
                                "is32BitModeEnabled": false,
                                "siteName": "[format('{0}-Portal', parameters('applicationName'))]",
                                "slots": [
                                    {
                                        "applicationSettings": [
                                            {
                                                "name": "A",
                                                "value": "9001"
                                            },
                                            {
                                                "name": "C",
                                                "value": "1337"
                                            }
                                        ],
                                        "slotName": "development"
                                    },
                                    {
                                        "applicationSettings": [
                                            {
                                                "name": "A",
                                                "value": "A"
                                            },
                                            {
                                                "name": "B",
                                                "value": "B"
                                            },
                                            {
                                                "name": "C",
                                                "value": "C"
                                            }
                                        ],
                                        "slotName": "staging"
                                    }
                                ],
                                "subnetName": "default",
                                "virtualNetworkName": "[variables('virtualNetworkSettings').virtualNetworkName]"
                            }
                        ]
                    },
                    "skuName": {
                        "value": "S1"
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftWebAppServerFarm')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        }
    ]
}
