{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "resourceDefinitions": {
            "type": "object"
        },
        "tags": {
            "type": "object"
        },
        "templateBaseUri": {
            "defaultValue": "https://dev.azure.com/ByteTerrace/Azure/_apis/git/repositories/ResourceManager.Templates/",
            "type": "string"
        },
        "templateQueryString": {
            "defaultValue": "&recursionLevel=0&versionDescriptor.version=master&versionDescriptor.versionOptions=0&versionDescriptor.versionType=0&includeContent=true&resolveLfs=true",
            "type": "string"
        }
    },
    "variables": {
        "defaultResourceDefinitions": {
            "dnsZones": [],
            "keyVaults": [],
            "storageAccounts": [],
            "virtualNetworks": []
        },
        "defaultResourceProperties": {
            "dnsZone": {
                "type": "Public"
            },
            "keyVault": {},
            "storageAccount": {},
            "virtualNetwork": {
                "addressPrefixes": [],
                "ddosProtectionPlanName": "",
                "ddosProtectionPlanResourceGroupName": "[resourceGroup().name]",
                "ddosProtectionPlanSubscriptionId": "[subscription().subscriptionId]"
            }
        },
        "deploymentApiVersion": "2019-10-01",
        "deployments": {
            "dnsZone": {
                "name": "[format('{0}-DnsZone', deployment().name)]",
                "resourceId": "[resourceId('Microsoft.Resources/deployments', variables('deployments').dnsZone.name)]"
            },
            "keyVault": {
                "name": "[format('{0}-KeyVault', deployment().name)]",
                "resourceId": "[resourceId('Microsoft.Resources/deployments', variables('deployments').keyVault.name)]"
            },
            "storageAccount": {
                "name": "[format('{0}-StorageAccount', deployment().name)]",
                "resourceId": "[resourceId('Microsoft.Resources/deployments', variables('deployments').storageAccount.name)]"
            },
            "virtualNetwork": {
                "name": "[format('{0}-VirtualNetwork', deployment().name)]",
                "resourceId": "[resourceId('Microsoft.Resources/deployments', variables('deployments').virtualNetwork.name)]"
            }
        },
        "resourceDefinitions": "[union(variables('defaultResourceDefinitions'), parameters('resourceDefinitions'))]",
        "templateUris": {
            "dnsZone": "[uri(parameters('templateBaseUri'), format('Items?path={0}{1}', uriComponent('/Microsoft.Network/dnsZones.json'), parameters('templateQueryString')))]",
            "keyVault": "[uri(parameters('templateBaseUri'), format('Items?path={0}{1}', uriComponent('/Microsoft.KeyVault/vaults.json'), parameters('templateQueryString')))]",
            "storageAccount": "[uri(parameters('templateBaseUri'), format('Items?path={0}{1}', uriComponent('/Microsoft.Storage/storageAccounts.json'), parameters('templateQueryString')))]",
            "virtualNetwork": "[uri(parameters('templateBaseUri'), format('Items?path={0}{1}', uriComponent('/Microsoft.Network/virtualNetworks.json'), parameters('templateQueryString')))]"
        }
    },
    "resources": [
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "condition": "[not(empty(variables('resourceDefinitions').virtualNetworks))]",
            "copy": {
                "count": "[length(variables('resourceDefinitions').virtualNetworks)]",
                "mode": "parallel",
                "name": "virtualNetworksCopy"
            },
            "name": "[format('{0}_{1}', variables('deployments').virtualNetwork.name, copyIndex())]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "addressPrefixes": {
                        "value": "[union(variables('defaultResourceProperties').virtualNetwork, variables('resourceDefinitions').virtualNetworks[copyIndex()]).addressPrefixes]"
                    },
                    "ddosProtectionPlanName": {
                        "value": "[union(variables('defaultResourceProperties').virtualNetwork, variables('resourceDefinitions').virtualNetworks[copyIndex()]).ddosProtectionPlanName]"
                    },
                    "ddosProtectionPlanResourceGroupName": {
                        "value": "[union(variables('defaultResourceProperties').virtualNetwork, variables('resourceDefinitions').virtualNetworks[copyIndex()]).ddosProtectionPlanResourceGroupName]"
                    },
                    "ddosProtectionPlanSubscriptionId": {
                        "value": "[union(variables('defaultResourceProperties').virtualNetwork, variables('resourceDefinitions').virtualNetworks[copyIndex()]).ddosProtectionPlanSubscriptionId]"
                    },
                    "name": {
                        "value": "[variables('resourceDefinitions').virtualNetworks[copyIndex()].name]"
                    },
                    "tags": {
                        "value": "[parameters('tags')]"
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('templateUris').virtualNetwork]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "condition": "[not(empty(variables('resourceDefinitions').dnsZones))]",
            "copy": {
                "count": "[length(variables('resourceDefinitions').dnsZones)]",
                "mode": "parallel",
                "name": "dnsZonesCopy"
            },
            "dependsOn": [
                "[variables('deployments').virtualNetwork.resourceId]"
            ],
            "name": "[format('{0}_{1}', variables('deployments').dnsZone.name, copyIndex())]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "name": {
                        "value": "[variables('resourceDefinitions').dnsZones[copyIndex()].name]"
                    },
                    "tags": {
                        "value": "[parameters('tags')]"
                    },
                    "type": {
                        "value": "[union(variables('defaultResourceProperties').dnsZone, variables('resourceDefinitions').dnsZones[copyIndex()]).type]"
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('templateUris').dnsZone]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        }
    ]
}
