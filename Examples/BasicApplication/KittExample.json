{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "2.0.0.0",
    "parameters": {
        "environmentSettings": {
            "type": "object"
        },
        "templateBaseUri": {
            "defaultValue": "https://dev.azure.com/ByteTerrace/Azure/_apis/git/repositories/Azure.ResourceManager.Templates/",
            "type": "string"
        },
        "templateQueryString": {
            "defaultValue": "&recursionLevel=0&versionDescriptor.version=master&versionDescriptor.versionOptions=0&versionDescriptor.versionType=0&includeContent=true&resolveLfs=true",
            "type": "string"
        }
    },
    "variables": {
        "deploymentApiVersion": "2019-10-01",
        "deploymentNameForMicrosoftAppConfiguration": "[format('{0}-AppConfiguration', deployment().name)]",
        "deploymentNameForMicrosoftKeyVault": "[format('{0}-KeyVault', deployment().name)]",
        "deploymentNameForMicrosoftSqlServer": "[format('{0}-SqlServer', deployment().name)]",
        "deploymentNameForMicrosoftStorageAccount": "[format('{0}-StorageAccount', deployment().name)]",
        "deploymentNameForMicrosoftVirtualNetwork": "[format('{0}-VirtualNetwork', deployment().name)]",
        "deploymentNameForMicrosoftWebServer": "[format('{0}-WebServer', deployment().name)]",
        "templateUriForMicrosoftAppConfiguration": "[uri(parameters('templateBaseUri'), format('Items?path={0}{1}', uriComponent('/Microsoft.AppConfiguration/configurationStores.json'), parameters('templateQueryString')))]",
        "templateUriForMicrosoftKeyVault": "[uri(parameters('templateBaseUri'), format('Items?path={0}{1}', uriComponent('/Microsoft.KeyVault/vaults.json'), parameters('templateQueryString')))]",
        "templateUriForMicrosoftSqlServer": "[uri(parameters('templateBaseUri'), format('Items?path={0}{1}', uriComponent('/Microsoft.Sql/servers.json'), parameters('templateQueryString')))]",
        "templateUriForMicrosoftStorageAccount": "[uri(parameters('templateBaseUri'), format('Items?path={0}{1}', uriComponent('/Microsoft.Storage/storageAccounts.json'), parameters('templateQueryString')))]",
        "templateUriForMicrosoftVirtualNetwork": "[uri(parameters('templateBaseUri'), format('Items?path={0}{1}', uriComponent('/Microsoft.Network/virtualNetworks.json'), parameters('templateQueryString')))]",
        "templateUriForMicrosoftWebAppServerFarm": "[uri(parameters('templateBaseUri'), format('Items?path={0}{1}', uriComponent('/Microsoft.Web/serverfarms.json'), parameters('templateQueryString')))]"
    },
    "resources": [
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "name": "[variables('deploymentNameForMicrosoftVirtualNetwork')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "subnets": {
                        "value": "[parameters('environmentSettings').virtualNetwork.subnets]"
                    },
                    "virtualNetworkName": {
                        "value": "[parameters('environmentSettings').virtualNetwork.name]"
                    }
                },
                "templateLink": {
                    "contentVersion": "2.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftVirtualNetwork')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "dependsOn": [
                "[variables('deploymentNameForMicrosoftVirtualNetwork')]"
            ],
            "name": "[variables('deploymentNameForMicrosoftKeyVault')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "accessPolicies": {
                        "value": "[parameters('environmentSettings').keyVault.accessPolicies]"
                    },
                    "firewallRules": {
                        "value": "[parameters('environmentSettings').keyVault.firewallRules]"
                    },
                    "isAllowTrustedMicrosoftServicesEnabled": {
                        "value": "[parameters('environmentSettings').keyVault.isAllowTrustedMicrosoftServicesEnabled]"
                    },
                    "keyVaultName": {
                        "value": "[parameters('environmentSettings').keyVault.name]"
                    },
                    "virtualNetworkRules": {
                        "value": "[parameters('environmentSettings').keyVault.virtualNetworkRules]"
                    }
                },
                "templateLink": {
                    "contentVersion": "2.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftKeyVault')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "dependsOn": [
                "[variables('deploymentNameForMicrosoftKeyVault')]"
            ],
            "name": "[variables('deploymentNameForMicrosoftAppConfiguration')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "configurationStoreName": {
                        "value": "[parameters('environmentSettings').configurationStore.name]"
                    }
                },
                "templateLink": {
                    "contentVersion": "2.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftAppConfiguration')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "dependsOn": [
                "[variables('deploymentNameForMicrosoftKeyVault')]",
                "[variables('deploymentNameForMicrosoftVirtualNetwork')]"
            ],
            "name": "[variables('deploymentNameForMicrosoftStorageAccount')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "firewallRules": {
                        "value": "[parameters('environmentSettings').storageAccount.firewallRules]"
                    },
                    "isAllowTrustedMicrosoftServicesEnabled": {
                        "value": "[parameters('environmentSettings').storageAccount.isAllowTrustedMicrosoftServicesEnabled]"
                    },
                    "linkedTemplateBaseUri": {
                        "value": "[parameters('templateBaseUri')]"
                    },
                    "linkedTemplateQueryString": {
                        "value": "[parameters('templateQueryString')]"
                    },
                    "storageAccountName": {
                        "value": "[parameters('environmentSettings').storageAccount.name]"
                    },
                    "virtualNetworkRules": {
                        "value": "[parameters('environmentSettings').storageAccount.virtualNetworkRules]"
                    }
                },
                "templateLink": {
                    "contentVersion": "2.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftStorageAccount')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "condition": "[greater(length(parameters('environmentSettings').sqlServers), 0)]",
            "copy": {
                "count": "[length(parameters('environmentSettings').sqlServers)]",
                "mode": "parallel",
                "name": "sqlServersCopy"
            },
            "dependsOn": [
                "[variables('deploymentNameForMicrosoftKeyVault')]",
                "[variables('deploymentNameForMicrosoftStorageAccount')]",
                "[variables('deploymentNameForMicrosoftVirtualNetwork')]"
            ],
            "name": "[format('{0}_{1}', variables('deploymentNameForMicrosoftSqlServer'), copyIndex())]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "auditStorageAccountName": {
                        "value": "[parameters('environmentSettings').sqlServers[copyIndex()].auditStorageAccountName]"
                    },
                    "databases": {
                        "value": "[parameters('environmentSettings').sqlServers[copyIndex()].databases]"
                    },
                    "firewallRules": {
                        "value": "[parameters('environmentSettings').sqlServers[copyIndex()].firewallRules]"
                    },
                    "linkedTemplateBaseUri": {
                        "value": "[parameters('templateBaseUri')]"
                    },
                    "linkedTemplateQueryString": {
                        "value": "[parameters('templateQueryString')]"
                    },
                    "serverName": {
                        "value": "[parameters('environmentSettings').sqlServers[copyIndex()].name]"
                    },
                    "virtualNetworkRules": {
                        "value": "[parameters('environmentSettings').sqlServers[copyIndex()].virtualNetworkRules]"
                    },
                    "vulnerabilityAssessmentStorageAccountName": {
                        "value": "[parameters('environmentSettings').sqlServers[copyIndex()].vulnerabilityAssessmentStorageAccountName]"
                    }
                },
                "templateLink": {
                    "contentVersion": "2.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftSqlServer')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "condition": "[greater(length(parameters('environmentSettings').appServicePlans), 0)]",
            "copy": {
                "count": "[length(parameters('environmentSettings').appServicePlans)]",
                "mode": "parallel",
                "name": "appServicePlansCopy"
            },
            "dependsOn": [
                "[variables('deploymentNameForMicrosoftKeyVault')]",
                "[variables('deploymentNameForMicrosoftStorageAccount')]",
                "[variables('deploymentNameForMicrosoftVirtualNetwork')]"
            ],
            "name": "[format('{0}_{1}', variables('deploymentNameForMicrosoftWebServer'), copyIndex())]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "servicePlanName": {
                        "value": "[parameters('environmentSettings').appServicePlans[copyIndex()].name]"
                    },
                    "sites": {
                        "value": "[parameters('environmentSettings').appServicePlans[copyIndex()].sites]"
                    },
                    "skuName": {
                        "value": "[parameters('environmentSettings').appServicePlans[copyIndex()].skuName]"
                    }
                },
                "templateLink": {
                    "contentVersion": "2.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftWebAppServerFarm')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        }
    ]
}
