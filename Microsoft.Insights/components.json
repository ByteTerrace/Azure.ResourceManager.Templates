{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Specifies the location in which the Azure Application Insights component resource(s) should be deployed."
            },
            "type": "string"
        },
        "logAnalyticsWorkspaceName": {
            "defaultValue": "",
            "metadata": {
                "description": ""
            },
            "type": "string"
        },
        "name": {
            "maxLength": 260,
            "metadata": {
                "description": "Specifies the name of the Azure Application Insights component."
            },
            "minLength": 1,
            "type": "string"
        },
        "tags": {
            "defaultValue": {},
            "metadata": {
                "description": "Specifies the set of tag key-value pairs that will be assigned to the Azure Application Insights  component."
            },
            "type": "object"
        }
    },
    "resources": [
        {
            "apiVersion": "2020-02-02-preview",
            "kind": "web",
            "location": "[parameters('location')]",
            "name": "[parameters('name')]",
            "properties": {
                "Application_Type": "web",
                "Flow_Type": "Bluefield",
                "Request_Source": "rest",
                "SamplingPercentage": 100,
                "WorkspaceResourceId": "[if(not(empty(parameters('logAnalyticsWorkspaceName'))), resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName')), json('null'))]"
            },
            "tags": "[parameters('tags')]",
            "type": "Microsoft.Insights/components"
        }
    ]
}
