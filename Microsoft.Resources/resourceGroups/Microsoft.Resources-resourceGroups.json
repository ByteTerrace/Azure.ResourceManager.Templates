{
    "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "location": {
            "defaultValue": "[deployment().location]",
            "metadata": {
                "description": "Specifies the location in which the Azure resource(s) will be deployed."
            },
            "type": "string"
        },
        "resourceGroupName": {
            "maxLength": 90,
            "metadata": {
                "description": "Specifies the name of the the Azure resource group in which the Azure resource(s) will be deployed."
            },
            "minLength": 1,
            "type": "string"
        },
        "tags": {
            "defaultValue": {},
            "metadata": {
                "description": "Specifies the set of tag key-value pairs that will be assigned to the Azure Resource Group."
            },
            "type": "object"
        }
    },
    "variables": {
        "resourcesResourceGroupsApiVersion":"2019-10-01"
    },
    "resources": [
        {
            "apiVersion": "[variables('resourcesResourceGroupsApiVersion')]",
            "location": "[parameters('location')]",
            "name": "[parameters('resourceGroupName')]",
            "properties": {},
            "tags": "[parameters('tags')]",
            "type": "Microsoft.Resources/resourceGroups"
        }
    ]
}
