{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "activeDirectoryAdministratorObjectId": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the Active Directory administrator object ID that will be assigned to the Azure SQL server."
            },
            "type": "string"
        },
        "activeDirectoryAdministratorTenantId": {
            "defaultValue": "[subscription().tenantId]",
            "metadata": {
                "description": "Specifies the Active Directory administrator tenant ID that will be assigned to the Azure SQL server."
            },
            "type": "string"
        },
        "activeDirectoryAdministratorUserName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the Active Directory administrator user name that will be assigned to the Azure SQL server."
            },
            "type": "string"
        },
        "connectionPolicy": {
            "allowedValues": [
                "Default",
                "Proxy",
                "Redirect"
            ],
            "defaultValue": "Default",
            "metadata": {
                "description": "Specifies how clients will connect to the Azure SQL server."
            },
            "type": "string"
        },
        "customerManagedEncryptionKeyName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the name of the customer-managed data encryption key."
            },
            "type": "string"
        },
        "customerManagedEncryptionKeyVaultName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the name of the key vault that houses the customer-managed data encryption key."
            },
            "type": "string"
        },
        "customerManagedEncryptionKeyVaultResourceGroupName": {
            "defaultValue": "[resourceGroup().name]",
            "metadata": {
                "description": "Specifies the resource group name of the key vault that houses the customer-managed data encryption key."
            },
            "type": "string"
        },
        "customerManagedEncryptionKeyVaultSubscriptionId": {
            "defaultValue": "[subscription().subscriptionId]",
            "metadata": {
                "description": "Specifies the subscrioption id of the key vault that houses the customer-managed data encryption key."
            },
            "type": "string"
        },
        "customerManagedEncryptionKeyVersion": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the version of the customer-managed data encryption key."
            },
            "type": "string"
        },
        "databases": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of databases that will be created within the Azure SQL server."
            },
            "type": "array"
        },
        "dnsAliases": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of dns aliases that will be assigned to the Azure SQL server."
            },
            "type": "array"
        },
        "firewallRules": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of firewall rules that will be assigned to the Azure SQL server."
            },
            "type": "array"
        },
        "isPublicNetworkAccessEnabled": {
            "defaultValue": true,
            "metadata": {
                "description": "Indicates whether the public network access feature is enabled on the Azure SQL server."
            },
            "type": "bool"
        },
        "isTrustedMicrosoftResourceAccessEnabled": {
            "defaultValue": false,
            "metadata": {
                "description": "Indicates whether trusted Azure services and resources are allowed to access the Azure SQL server."
            },
            "type": "bool"
        },
        "linkedTemplateBaseUri": {
            "defaultValue": "https://dev.azure.com/ByteTerrace/Azure/_apis/git/repositories/ResourceManager.Templates/",
            "metadata": {
                "description": "Specifies the base uri of external linked templates used by this template."
            },
            "type": "string"
        },
        "linkedTemplateQueryString": {
            "defaultValue": "&recursionLevel=0&versionDescriptor.version=master&versionDescriptor.versionOptions=0&versionDescriptor.versionType=0&includeContent=true&resolveLfs=true",
            "metadata": {
                "description": "Specifies the query string that will be appended to the uri of external linked templates used by this template."
            },
            "type": "string"
        },
        "location": {
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Specifies the location in which the Azure SQL server resource(s) will be deployed."
            },
            "type": "string"
        },
        "name": {
            "maxLength": 63,
            "metadata": {
                "description": "Specifies the name of the Azure SQL server."
            },
            "type": "string",
            "minLength": 1
        },
        "serverVersion": {
            "allowedValues": [
                "12.0"
            ],
            "defaultValue": "12.0",
            "metadata": {
                "description": "Specifies the version of the Azure SQL server."
            },
            "type": "string"
        },
        "sqlAdministratorUserName": {
            "defaultValue": "[uniqueString(toLower(parameters('name')))]",
            "metadata": {
                "description": "Specifies the default SQL administrator user name that will be assigned to the Azure SQL server."
            },
            "type": "securestring"
        },
        "sqlAdministratorUserPassword": {
            "defaultValue": "[base64(format('{0}|{1}', newGuid(), newGuid()))]",
            "metadata": {
                "description": "Specifies the default SQL administrator user password that will be assigned to the Azure SQL server."
            },
            "type": "securestring"
        },
        "tags": {
            "defaultValue": {},
            "metadata": {
                "description": "Specifies the set of tag key-value pairs that will be assigned to the Azure SQL server."
            },
            "type": "object"
        },
        "virtualNetworkRules": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of virtual network rules that will be assigned to the Azure SQL server."
            },
            "type": "array"
        }
    },
    "variables": {
        "administratorsApiVersion": "2019-06-01-preview",
        "administratorResourceId": "[resourceId('Microsoft.Sql/servers/administrators', variables('serverName'), 'activeDirectory')]",
        "connectionPoliciesApiVersion": "2014-04-01",
        "customerManagedEncryptionKeyVaultResourceId": "[resourceId(variables('customerManagedEncryptionProperties').subscriptionId, variables('customerManagedEncryptionProperties').resourceGroupName, 'Microsoft.KeyVault/vaults', parameters('customerManagedEncryptionKeyVaultName'))]",
        "customerManagedEncryptionProperties": {
            "isEnabled": "[and(not(empty(coalesce(parameters('customerManagedEncryptionKeyVaultName'), ''))), not(empty(coalesce(parameters('customerManagedEncryptionKeyName'), ''))), not(empty(coalesce(parameters('customerManagedEncryptionKeyVersion'), ''))))]",
            "keyName": "[format('{0}_{1}_{2}', if(not(empty(coalesce(parameters('customerManagedEncryptionKeyVaultName'), ''))), parameters('customerManagedEncryptionKeyVaultName'), 'DummyVault'), if(not(empty(coalesce(parameters('customerManagedEncryptionKeyName'), ''))), parameters('customerManagedEncryptionKeyName'), 'DummyKey'), if(not(empty(coalesce(parameters('customerManagedEncryptionKeyVersion'), ''))), parameters('customerManagedEncryptionKeyVersion'), 'DummyVersion'))]",
            "resourceGroupName": "[if(not(empty(coalesce(parameters('customerManagedEncryptionKeyVaultResourceGroupName'), ''))), parameters('customerManagedEncryptionKeyVaultResourceGroupName'), resourceGroup().name)]",
            "subscriptionId": "[if(not(empty(coalesce(parameters('customerManagedEncryptionKeyVaultSubscriptionId'), ''))), parameters('customerManagedEncryptionKeyVaultSubscriptionId'), subscription().subscriptionId)]"
        },
        "customerManagedEncryptionServerKeyResourceId": "[resourceId('Microsoft.Sql/servers/keys', variables('serverName'), variables('customerManagedEncryptionProperties').keyName)]",
        "databases": "[if(variables('databasesIsNotEmpty'), parameters('databases'), createArray(createObject('name', 'DummyDatabase')))]",
        "databasesDefaultProperties": {
            "catalogCollation": "DATABASE_DEFAULT",
            "defaultCollation": "SQL_Latin1_General_CP1_CI_AS",
            "isAzureHybridBenefitEnabled": false,
            "skuName": "Basic"
        },
        "databasesIsNotEmpty": "[greater(length(parameters('databases')), 0)]",
        "deploymentsApiVersion": "2020-10-01",
        "dnsAliasesApiVersion": "2017-03-01-preview",
        "dnsAliases": "[if(variables('dnsAliasesIsNotEmpty'), parameters('dnsAliases'), createArray('dummyDnsAlias'))]",
        "dnsAliasesIsNotEmpty": "[greater(length(parameters('dnsAliases')), 0)]",
        "encryptionProtectorApiVersion": "2015-05-01-preview",
        "firewallRulesApiVersion": "2015-05-01-preview",
        "firewallRules": "[if(variables('firewallRulesIsNotEmpty'), parameters('firewallRules'), createArray(createObject('endIpAddress', '0.0.0.0', 'name', 'DummyRule', 'startIpAddress', '0.0.0.0')))]",
        "firewallRulesIsNotEmpty": "[greater(length(parameters('firewallRules')), 0)]",
        "isActiveDirectoryAdministratorEnabled": "[or(not(empty(coalesce(parameters('activeDirectoryAdministratorObjectId'), ''))), not(empty(coalesce(parameters('activeDirectoryAdministratorUserName'), ''))))]",
        "keysApiVersion": "2015-05-01-preview",
        "keyVaultsApiVersion": "2019-09-01",
        "serversApiVersion": "2019-06-01-preview",
        "serverName": "[toLower(parameters('name'))]",
        "serverResourceId": "[resourceId('Microsoft.Sql/servers', variables('serverName'))]",
        "templateUriForMicrosoftSqlDatabases": "[uri(parameters('linkedTemplateBaseUri'), format('Items?path={0}{1}', uriComponent('/Microsoft.Sql/databases.json'), parameters('linkedTemplateQueryString')))]",
        "virtualNetworkRulesApiVersion": "2015-05-01-preview",
        "virtualNetworkRules": "[if(variables('virtualNetworkRulesIsNotEmpty'), parameters('virtualNetworkRules'), createArray(createObject('name', 'DummyRule')))]",
        "virtualNetworkRulesDefaultProperties": {
            "ignoreMissingVnetServiceEndpoint": false,
            "resourceGroupName": "[resourceGroup().name]",
            "subscriptionId": "[subscription().subscriptionId]"
        },
        "virtualNetworkRulesIsNotEmpty": "[greater(length(parameters('virtualNetworkRules')), 0)]"
    },
    "resources": [
        {
            "apiVersion": "[variables('serversApiVersion')]",
            "identity": {
                "type": "SystemAssigned"
            },
            "location": "[parameters('location')]",
            "name": "[variables('serverName')]",
            "properties": {
                "administratorLogin": "[parameters('sqlAdministratorUserName')]",
                "administratorLoginPassword": "[parameters('sqlAdministratorUserPassword')]",
                "minimalTlsVersion": "1.2",
                "publicNetworkAccess": "[if(parameters('isPublicNetworkAccessEnabled'), 'Enabled', 'Disabled')]",
                "version": "[parameters('serverVersion')]"
            },
            "tags": "[parameters('tags')]",
            "type": "Microsoft.Sql/servers"
        },
        {
            "apiVersion": "[variables('connectionPoliciesApiVersion')]",
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/default', variables('serverName'))]",
            "properties": {
                "connectionType": "[parameters('connectionPolicy')]"
            },
            "type": "Microsoft.Sql/servers/connectionPolicies"
        },
        {
            "apiVersion": "[variables('dnsAliasesApiVersion')]",
            "condition": "[variables('dnsAliasesIsNotEmpty')]",
            "copy": {
                "count": "[length(variables('dnsAliases'))]",
                "mode": "parallel",
                "name": "dnsAliasCopy"
            },
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/{1}', variables('serverName'), toLower(variables('dnsAliases')[copyIndex()]))]",
            "type": "Microsoft.Sql/servers/dnsAliases"
        },
        {
            "apiVersion": "[variables('firewallRulesApiVersion')]",
            "condition": "[parameters('isTrustedMicrosoftResourceAccessEnabled')]",
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/AllowAllWindowsAzureIps', variables('serverName'))]",
            "properties": {
                "endIpAddress": "0.0.0.0",
                "startIpAddress": "0.0.0.0"
            },
            "type": "Microsoft.Sql/servers/firewallRules"
        },
        {
            "apiVersion": "[variables('firewallRulesApiVersion')]",
            "condition": "[variables('firewallRulesIsNotEmpty')]",
            "copy": {
                "count": "[length(variables('firewallRules'))]",
                "mode": "parallel",
                "name": "firewallRulesCopy"
            },
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/{1}', variables('serverName'), variables('firewallRules')[copyIndex()].name)]",
            "properties": {
                "endIpAddress": "[variables('firewallRules')[copyIndex()].endIpAddress]",
                "startIpAddress": "[variables('firewallRules')[copyIndex()].startIpAddress]"
            },
            "type": "Microsoft.Sql/servers/firewallRules"
        },
        {
            "apiVersion": "[variables('virtualNetworkRulesApiVersion')]",
            "condition": "[variables('virtualNetworkRulesIsNotEmpty')]",
            "copy": {
                "count": "[length(variables('virtualNetworkRules'))]",
                "mode": "parallel",
                "name": "virtualNetworkRulesCopy"
            },
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/{1}', variables('serverName'), variables('virtualNetworkRules')[copyIndex()].name)]",
            "properties": {
                "ignoreMissingVnetServiceEndpoint": "[union(variables('virtualNetworkRulesDefaultProperties'), variables('virtualNetworkRules')[copyIndex()]).ignoreMissingVnetServiceEndpoint]",
                "virtualNetworkSubnetId": "[resourceId(union(variables('virtualNetworkRulesDefaultProperties'), variables('virtualNetworkRules')[copyIndex()]).subscriptionId, union(variables('virtualNetworkRulesDefaultProperties'), variables('virtualNetworkRules')[copyIndex()]).resourceGroupName, 'Microsoft.Network/virtualNetworks/subnets', variables('virtualNetworkRules')[copyIndex()].virtualNetworkName, variables('virtualNetworkRules')[copyIndex()].subnetName)]"
            },
            "type": "Microsoft.Sql/servers/virtualNetworkRules"
        },
        {
            "apiVersion": "[variables('administratorsApiVersion')]",
            "condition": "[variables('isActiveDirectoryAdministratorEnabled')]",
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/activeDirectory', variables('serverName'))]",
            "properties": {
                "administratorType": "ActiveDirectory",
                "login": "[parameters('activeDirectoryAdministratorUserName')]",
                "sid": "[parameters('activeDirectoryAdministratorObjectId')]",
                "tenantId": "[if(not(empty(coalesce(parameters('activeDirectoryAdministratorTenantId'), ''))), parameters('activeDirectoryAdministratorTenantId'), subscription().tenantId)]"
            },
            "type": "Microsoft.Sql/servers/administrators"
        },
        {
            "apiVersion": "[variables('keysApiVersion')]",
            "condition": "[variables('customerManagedEncryptionProperties').isEnabled]",
            "dependsOn": [
                "[variables('serverResourceId')]",
                "[variables('administratorResourceId')]"
            ],
            "kind": "AzureKeyVault",
            "name": "[format('{0}/{1}', variables('serverName'), variables('customerManagedEncryptionProperties').keyName)]",
            "properties": {
                "serverKeyType": "AzureKeyVault",
                "uri": "[if(variables('customerManagedEncryptionProperties').isEnabled, format('{0}keys/{1}/{2}', reference(variables('customerManagedEncryptionKeyVaultResourceId'), variables('keyVaultsApiVersion')).vaultUri, parameters('customerManagedEncryptionKeyName'), parameters('customerManagedEncryptionKeyVersion')), json('null'))]"
            },
            "type": "Microsoft.Sql/servers/keys"
        },
        {
            "apiVersion": "[variables('encryptionProtectorApiVersion')]",
            "condition": "[variables('customerManagedEncryptionProperties').isEnabled]",
            "dependsOn": [
                "[variables('administratorResourceId')]",
                "[variables('customerManagedEncryptionServerKeyResourceId')]",
                "[variables('serverResourceId')]"
            ],
            "kind": "AzureKeyVault",
            "name": "[format('{0}/current', variables('serverName'))]",
            "properties": {
                "serverKeyName": "[variables('customerManagedEncryptionProperties').keyName]",
                "serverKeyType": "AzureKeyVault"
            },
            "type": "Microsoft.Sql/servers/encryptionProtector"
        },
        {
            "apiVersion": "[variables('deploymentsApiVersion')]",
            "condition": "[variables('databasesIsNotEmpty')]",
            "copy": {
                "count": "[length(variables('databases'))]",
                "mode": "parallel",
                "name": "databasesCopy"
            },
            "dependsOn": [
                "[variables('serverResourceId')]",
                "[variables('administratorResourceId')]"
            ],
            "name": "[format('{0}-database_{1}', deployment().name, copyIndex())]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "catalogCollation": {
                        "value": "[union(variables('databasesDefaultProperties'), variables('databases')[copyIndex()]).catalogCollation]"
                    },
                    "databaseName": {
                        "value": "[variables('databases')[copyIndex()].databaseName]"
                    },
                    "defaultCollation": {
                        "value": "[union(variables('databasesDefaultProperties'), variables('databases')[copyIndex()]).defaultCollation]"
                    },
                    "isAzureHybridBenefitEnabled": {
                        "value": "[union(variables('databasesDefaultProperties'), variables('databases')[copyIndex()]).isAzureHybridBenefitEnabled]"
                    },
                    "location": {
                        "value": "[parameters('location')]"
                    },
                    "serverName": {
                        "value": "[variables('serverName')]"
                    },
                    "skuName": {
                        "value": "[union(variables('databasesDefaultProperties'), variables('databases')[copyIndex()]).skuName]"
                    },
                    "tags": {
                        "value": "[parameters('tags')]"
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('templateUriForMicrosoftSqlDatabases')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        }
    ]
}
