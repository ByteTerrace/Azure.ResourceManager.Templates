{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "activeDirectoryAdministratorObjectId": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the Active Directory administrator object ID that will be assigned to the Azure SQL server."
            },
            "type": "string"
        },
        "activeDirectoryAdministratorTenantId": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the Active Directory administrator tenant ID that will be assigned to the Azure SQL server."
            },
            "type": "string"
        },
        "activeDirectoryAdministratorUserName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the Active Directory administrator user name that will be assigned to the Azure SQL server."
            },
            "type": "string"
        },
        "advancedDataSecurityDisabledAlerts": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of alert names that will be disabled within the advanced data security feature, if enabled."
            },
            "type": "array"
        },
        "advancedDataSecurityEmailAddresses": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of email addresses that will be notified by the advanced data security feature, if enabled."
            },
            "type": "array"
        },
        "advancedDataSecurityStorageAccountName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the name of the Azure Storage account that will be utilized by the advanced data security feature, if enabled."
            },
            "type": "string"
        },
        "advancedDataSecurityStorageAccountResourceGroupName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the resource group name of the Azure Storage account that will be utilized by the advanced data security feature, if enabled."
            },
            "type": "string"
        },
        "connectionPolicy": {
            "allowedValues": [
                "Default",
                "Proxy",
                "Redirect"
            ],
            "defaultValue": "Default",
            "metadata": {
                "description": "Specifies how clients will connect to the Azure SQL server."
            },
            "type": "string"
        },
        "databases": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of databases that will be created within the Azure SQL server."
            },
            "type": "array"
        },
        "dnsAliases": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of dns aliases that will be assigned to the Azure SQL server."
            },
            "type": "array"
        },
        "encryptionKeyVaultKeyName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the name of the customer-managed data encryption key."
            },
            "type": "string"
        },
        "encryptionKeyVaultKeyVersion": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the version of the customer-managed data encryption key."
            },
            "type": "string"
        },
        "encryptionKeyVaultName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the name of the key vault that houses the customer-managed data encryption key."
            },
            "type": "string"
        },
        "encryptionKeyVaultResourceGroupName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the resource group name of the key vault that houses the customer-managed data encryption key."
            },
            "type": "string"
        },
        "firewallRules": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of firewall rules that will be assigned to the Azure SQL server."
            },
            "type": "array"
        },
        "location": {
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Specifies the location in which the Azure SQL server resource(s) will be deployed."
            },
            "type": "string"
        },
        "isAzureResourceAccessEnabled": {
            "defaultValue": false,
            "metadata": {
                "description": "Indicates whether Azure services and resources are allowed to access the Azure SQL server."
            },
            "type": "bool"
        },
        "isPublicNetworkAccessEnabled": {
            "defaultValue": false,
            "metadata": {
                "description": "Indicates whether the public network access feature is enabled on the Azure SQL server."
            },
            "type": "bool"
        },
        "serverName": {
            "metadata": {
                "description": "Specifies the name of the Azure SQL server."
            },
            "type": "string"
        },
        "serverVersion": {
            "allowedValues": [
                "12.0"
            ],
            "defaultValue": "12.0",
            "metadata": {
                "description": "Specifies the version of the Azure SQL server."
            },
            "type": "string"
        },
        "sqlAdministratorUserName": {
            "defaultValue": "[uniqueString(parameters('serverName'))]",
            "metadata": {
                "description": "Specifies the default SQL administrator user name that will be assigned to the Azure SQL server."
            },
            "type": "securestring"
        },
        "sqlAdministratorUserPassword": {
            "defaultValue": "[newGuid()]",
            "metadata": {
                "description": "Specifies the default SQL administrator user password that will be assigned to the Azure SQL server."
            },
            "type": "securestring"
        },
        "tags": {
            "defaultValue": {},
            "metadata": {
                "description": "Specifies the set of tag key-value pairs that will be assigned to the Azure SQL server."
            },
            "type": "object"
        },
        "virtualNetworkRules": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of virtual network rules that will be assigned to the Azure SQL server."
            },
            "type": "array"
        }
    },
    "variables": {
        "administratorApiVersion": "2019-06-01-preview",
        "advancedDataSecurityStorageAccountIsEnabled": "[or(not(empty(coalesce(parameters('advancedDataSecurityStorageAccountResourceGroupName'), ''))), not(empty(coalesce(parameters('advancedDataSecurityStorageAccountName'), ''))))]",
        "advancedDataSecurityStorageAccountName": "[if(not(empty(coalesce(parameters('advancedDataSecurityStorageAccountName'), ''))), parameters('advancedDataSecurityStorageAccountName'), 'DummyStorageAccount')]",
        "advancedDataSecurityStorageAccountResourceGroupName": "[if(not(empty(coalesce(parameters('advancedDataSecurityStorageAccountResourceGroupName'), ''))), parameters('advancedDataSecurityStorageAccountResourceGroupName'), resourceGroup().name)]",
        "advancedDataSecurityStorageBlobDataContributorRoleAssignmentResourceId": "[resourceId('Microsoft.Storage/storageAccounts/providers/roleAssignments', variables('advancedDataSecurityStorageAccountName'), 'Microsoft.Authorization', variables('advancedDataSecurityStorageBlobDataContributorRoleAssignmentUniqueId'))]",
        "advancedDataSecurityStorageBlobDataContributorRoleAssignmentUniqueId": "[guid(resourceId('Microsoft.Storage/storageAccounts', parameters('advancedDataSecurityStorageAccountName')), variables('storageBlobDataContributorRoleResourceId'), variables('serverResourceId'))]",
        "authorizationRoleAssignmentApiVersion": "2018-09-01-preview",
        "connectionPolicyApiVersion": "2014-04-01",
        "databasesApiVersion": "2019-06-01-preview",
        "databases": "[if(variables('databasesIsNotEmpty'), parameters('databases'), json('[ { \"databaseName\": \"DummyDatabase\", \"sku\": { \"capacity\": 5, \"name\": \"Basic\", \"tier\": \"Basic\" } } ]'))]",
        "databasesCount": "[length(parameters('databases'))]",
        "databasesIsNotEmpty": "[greater(variables('databasesCount'), 0)]",
        "dnsAliasApiVersion": "2017-03-01-preview",
        "dnsAliases": "[if(variables('dnsAliasesIsNotEmpty'), parameters('dnsAliases'), json('[ \"dummyDnsAlias\" ]'))]",
        "dnsAliasesCount": "[length(parameters('dnsAliases'))]",
        "dnsAliasesIsNotEmpty": "[greater(variables('dnsAliasesCount'), 0)]",
        "encryptionProtectorApiVersion": "2015-05-01-preview",
        "firewallRuleApiVersion": "2015-05-01-preview",
        "firewallRules": "[if(variables('firewallRulesIsNotEmpty'), parameters('firewallRules'), json('[ { \"endIpAddress\": \"0.0.0.0\", \"ruleName\": \"dummyFirewallRule\", \"startIpAddress\": \"0.0.0.0\" }]'))]",
        "firewallRulesCount": "[length(parameters('firewallRules'))]",
        "firewallRulesIsNotEmpty": "[greater(variables('firewallRulesCount'), 0)]",
        "isActiveDirectoryAdministratorEnabled": "[or(not(empty(coalesce(parameters('activeDirectoryAdministratorObjectId'), ''))), not(empty(coalesce(parameters('activeDirectoryAdministratorTenantId'), ''))), not(empty(coalesce(parameters('activeDirectoryAdministratorUserName'), ''))))]",
        "isAdvancedDataSecurityEnabled": "[or(greater(length(parameters('advancedDataSecurityEmailAddresses')), 0), variables('advancedDataSecurityStorageAccountIsEnabled'))]",
        "keyApiVersion": "2015-05-01-preview",
        "keyVaultAccessPolicyApiVersion": "2018-02-14",
        "keyVaultAccessPolicyResourceId": "[resourceId('Microsoft.KeyVault/vaults/accessPolicies', variables('keyVaultEncryptionVaultName'), 'add')]",
        "keyVaultApiVersion": "2018-02-14",
        "keyVaultEncryptionIsEnabled": "[or(not(empty(coalesce(parameters('encryptionKeyVaultResourceGroupName'), ''))), not(empty(coalesce(parameters('encryptionKeyVaultName'), ''))), not(empty(coalesce(parameters('encryptionKeyVaultKeyName'), ''))))]",
        "keyVaultEncryptionKeyName": "[format('{0}_{1}_{2}', variables('keyVaultEncryptionVaultName'), if(not(empty(coalesce(parameters('encryptionKeyVaultKeyName'), ''))), parameters('encryptionKeyVaultKeyName'), 'DummyKeyName'), if(not(empty(coalesce(parameters('encryptionKeyVaultKeyVersion'), ''))), parameters('encryptionKeyVaultKeyVersion'), 'DummyKeyVersion'))]",
        "keyVaultEncryptionKeyResourceId": "[resourceId('Microsoft.Sql/servers/keys', variables('serverName'), variables('keyVaultEncryptionKeyName'))]",
        "keyVaultEncryptionResourceGroupName": "[if(not(empty(coalesce(parameters('encryptionKeyVaultResourceGroupName'), ''))), parameters('encryptionKeyVaultResourceGroupName'), resourceGroup().name)]",
        "keyVaultEncryptionVaultName": "[if(not(empty(coalesce(parameters('encryptionKeyVaultName'), ''))), parameters('encryptionKeyVaultName'), 'DummyKeyVault')]",
        "securityAlertPolicyApiVersion": "2017-03-01-preview",
        "securityAlertPolicyResourceId": "[resourceId('Microsoft.Sql/servers/securityAlertPolicies', variables('serverName'), 'default')]",
        "serverApiVersion": "2019-06-01-preview",
        "serverName": "[toLower(parameters('serverName'))]",
        "serverResourceId": "[resourceId('Microsoft.Sql/servers', parameters('serverName'))]",
        "storageAccountApiVersion": "2019-06-01",
        "storageBlobDataContributorRoleResourceId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'ba92f5b4-2d11-453d-a403-e96b0029c9fe')]",
        "virtualNetworkRuleApiVersion": "2015-05-01-preview",
        "virtualNetworkRules": "[if(variables('virtualNetworkRulesIsNotEmpty'), parameters('virtualNetworkRules'), json('[ { \"ignoreMissingVnetServiceEndpoint\": false, \"ruleName\": \"dummyVirtualNetworkRule\", \"subnetName\": \"dummySubnet\", \"virtualNetworkName\": \"dummyVirtualNetwork\", \"virtualNetworkResourceGroupName\": \"dummyResourceGroup\" } ]'))]",
        "virtualNetworkRulesCount": "[length(parameters('virtualNetworkRules'))]",
        "virtualNetworkRulesIsNotEmpty": "[greater(variables('virtualNetworkRulesCount'), 0)]",
        "vulnerabilityAssessmentApiVersion": "2018-06-01-preview",
        "vulnerabilityAssessmentResourceId": "[resourceId('Microsoft.Sql/servers/vulnerabilityAssessments', variables('serverName'), 'default')]"
    },
    "resources": [
        {
            "apiVersion": "[variables('serverApiVersion')]",
            "identity": {
                "type": "SystemAssigned"
            },
            "location": "[parameters('location')]",
            "name": "[variables('serverName')]",
            "properties": {
                "administratorLogin": "[parameters('sqlAdministratorUserName')]",
                "administratorLoginPassword": "[parameters('sqlAdministratorUserPassword')]",
                "minimalTlsVersion": "1.2",
                "publicNetworkAccess": "[if(parameters('isPublicNetworkAccessEnabled'), 'Enabled', 'Disabled')]",
                "version": "[parameters('serverVersion')]"
            },
            "tags": "[parameters('tags')]",
            "type": "Microsoft.Sql/servers"
        },
        {
            "apiVersion": "[variables('connectionPolicyApiVersion')]",
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/default', variables('serverName'))]",
            "properties": {
                "connectionType": "[parameters('connectionPolicy')]"
            },
            "type": "Microsoft.Sql/servers/connectionPolicies"
        },
        {
            "apiVersion": "[variables('dnsAliasApiVersion')]",
            "condition": "[variables('dnsAliasesIsNotEmpty')]",
            "copy": {
                "count": "[variables('dnsAliasesCount')]",
                "mode": "parallel",
                "name": "dnsAliasCopy"
            },
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/{1}', variables('serverName'), toLower(variables('dnsAliases')[copyIndex()]))]",
            "type": "Microsoft.Sql/servers/dnsAliases"
        },
        {
            "apiVersion": "[variables('firewallRuleApiVersion')]",
            "condition": "[parameters('isAzureResourceAccessEnabled')]",
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/AllowAllWindowsAzureIps', variables('serverName'))]",
            "properties": {
                "endIpAddress": "0.0.0.0",
                "startIpAddress": "0.0.0.0"
            },
            "type": "Microsoft.Sql/servers/firewallRules"
        },
        {
            "apiVersion": "[variables('firewallRuleApiVersion')]",
            "condition": "[variables('firewallRulesIsNotEmpty')]",
            "copy": {
                "count": "[variables('firewallRulesCount')]",
                "mode": "parallel",
                "name": "firewallRulesCopy"
            },
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/{1}', variables('serverName'), variables('firewallRules')[copyIndex()].ruleName)]",
            "properties": {
                "endIpAddress": "[variables('firewallRules')[copyIndex()].endIpAddress]",
                "startIpAddress": "[variables('firewallRules')[copyIndex()].startIpAddress]"
            },
            "type": "Microsoft.Sql/servers/firewallRules"
        },
        {
            "apiVersion": "[variables('virtualNetworkRuleApiVersion')]",
            "condition": "[variables('virtualNetworkRulesIsNotEmpty')]",
            "copy": {
                "count": "[variables('virtualNetworkRulesCount')]",
                "mode": "parallel",
                "name": "virtualNetworkRulesCopy"
            },
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/{1}', variables('serverName'), variables('virtualNetworkRules')[copyIndex()].ruleName)]",
            "properties": {
                "ignoreMissingVnetServiceEndpoint": "[variables('virtualNetworkRules')[copyIndex()].ignoreMissingVnetServiceEndpoint]",
                "virtualNetworkSubnetId": "[resourceId(variables('virtualNetworkRules')[copyIndex()].virtualNetworkResourceGroupName, 'Microsoft.Network/virtualNetworks/subnets', variables('virtualNetworkRules')[copyIndex()].virtualNetworkName, variables('virtualNetworkRules')[copyIndex()].subnetName)]"
            },
            "type": "Microsoft.Sql/servers/virtualNetworkRules"
        },
        {
            "apiVersion": "[variables('securityAlertPolicyApiVersion')]",
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/default', variables('serverName'))]",
            "properties": {
                "disabledAlerts": "[parameters('advancedDataSecurityDisabledAlerts')]",
                "emailAccountAdmins": true,
                "emailAddresses": "[parameters('advancedDataSecurityEmailAddresses')]",
                "retentionDays": 0,
                "state": "[if(variables('isAdvancedDataSecurityEnabled'), 'Enabled', 'Disabled')]"
            },
            "type": "Microsoft.Sql/servers/securityAlertPolicies"
        },
        {
            "apiVersion": "[variables('administratorApiVersion')]",
            "condition": "[variables('isActiveDirectoryAdministratorEnabled')]",
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/activeDirectory', variables('serverName'))]",
            "properties": {
                "administratorType": "ActiveDirectory",
                "login": "[parameters('activeDirectoryAdministratorUserName')]",
                "sid": "[parameters('activeDirectoryAdministratorObjectId')]",
                "tenantId": "[parameters('activeDirectoryAdministratorTenantId')]"
            },
            "type": "Microsoft.Sql/servers/administrators"
        },
        {
            "apiVersion": "[variables('keyVaultAccessPolicyApiVersion')]",
            "condition": "[variables('keyVaultEncryptionIsEnabled')]",
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/add', variables('keyVaultEncryptionVaultName'))]",
            "properties": {
                "accessPolicies": [
                    {
                        "objectId": "[reference(variables('serverResourceId'), variables('serverApiVersion'), 'Full').identity.principalId]",
                        "permissions": {
                            "certificates": [],
                            "keys": [
                                "Get",
                                "UnwrapKey",
                                "WrapKey"
                            ],
                            "secrets": []
                        },
                        "tenantId": "[subscription().tenantId]"
                    }
                ]
            },
            "type": "Microsoft.KeyVault/vaults/accessPolicies"
        },
        {
            "apiVersion": "[variables('keyApiVersion')]",
            "condition": "[variables('keyVaultEncryptionIsEnabled')]",
            "dependsOn": [
                "[variables('serverResourceId')]",
                "[variables('keyVaultAccessPolicyResourceId')]"
            ],
            "kind": "AzureKeyVault",
            "name": "[format('{0}/{1}', variables('serverName'), variables('keyVaultEncryptionKeyName'))]",
            "properties": {
                "serverKeyType": "AzureKeyVault",
                "uri": "[format('{0}keys/{1}/{2}', if(variables('keyVaultEncryptionIsEnabled'), reference(resourceId(variables('keyVaultEncryptionResourceGroupName'), 'Microsoft.KeyVault/vaults/', variables('keyVaultEncryptionVaultName')), variables('keyVaultApiVersion'), 'Full').properties.vaultUri, 'https://dummy.domain/'), parameters('encryptionKeyVaultKeyName'), parameters('encryptionKeyVaultKeyVersion'))]"
            },
            "type": "Microsoft.Sql/servers/keys"
        },
        {
            "apiVersion": "[variables('encryptionProtectorApiVersion')]",
            "condition": "[variables('keyVaultEncryptionIsEnabled')]",
            "dependsOn": [
                "[variables('serverResourceId')]",
                "[variables('keyVaultEncryptionKeyResourceId')]"
            ],
            "kind": "AzureKeyVault",
            "name": "[format('{0}/current', variables('serverName'))]",
            "properties": {
                "serverKeyName": "[variables('keyVaultEncryptionKeyName')]",
                "serverKeyType": "AzureKeyVault"
            },
            "type": "Microsoft.Sql/servers/encryptionProtector"
        },
        {
            "apiVersion": "[variables('authorizationRoleAssignmentApiVersion')]",
            "condition": "[variables('advancedDataSecurityStorageAccountIsEnabled')]",
            "dependsOn": [
                "[variables('serverResourceId')]",
                "[variables('securityAlertPolicyResourceId')]"
            ],
            "name": "[format('{0}/Microsoft.Authorization/{1}', variables('advancedDataSecurityStorageAccountName'), variables('advancedDataSecurityStorageBlobDataContributorRoleAssignmentUniqueId'))]",
            "properties": {
                "principalId": "[reference(variables('serverResourceId'), variables('serverApiVersion'), 'Full').identity.principalId]",
                "principalType": "ServicePrincipal",
                "roleDefinitionId": "[variables('storageBlobDataContributorRoleResourceId')]",
                "scope": "[resourceId('Microsoft.Storage/storageAccounts', parameters('advancedDataSecurityStorageAccountName'))]"
            },
            "type": "Microsoft.Storage/storageAccounts/providers/roleAssignments"
        },
        {
            "apiVersion": "[variables('vulnerabilityAssessmentApiVersion')]",
            "condition": "[variables('isAdvancedDataSecurityEnabled')]",
            "dependsOn": [
                "[variables('serverResourceId')]",
                "[variables('securityAlertPolicyResourceId')]",
                "[variables('advancedDataSecurityStorageBlobDataContributorRoleAssignmentResourceId')]"
            ],
            "name": "[format('{0}/default', variables('serverName'))]",
            "properties": {
                "recurringScans": {
                    "emails": "[parameters('advancedDataSecurityEmailAddresses')]",
                    "emailSubscriptionAdmins": true,
                    "isEnabled": "[variables('advancedDataSecurityStorageAccountIsEnabled')]"
                },
                "storageContainerPath": "[format('{0}vulnerability-assessment/', if(variables('advancedDataSecurityStorageAccountIsEnabled'), reference(resourceId(variables('advancedDataSecurityStorageAccountResourceGroupName'), 'Microsoft.Storage/storageAccounts', variables('advancedDataSecurityStorageAccountName')), variables('storageAccountApiVersion'), 'Full').properties.primaryEndpoints.blob, 'https://dummy.domain/'))]"
            },
            "type": "Microsoft.Sql/servers/vulnerabilityAssessments"
        },
        {
            "apiVersion": "[variables('databasesApiVersion')]",
            "condition": "[variables('databasesIsNotEmpty')]",
            "copy": {
                "count": "[variables('databasesCount')]",
                "mode": "parallel",
                "name": "databasesCopy"
            },
            "dependsOn": [
                "[variables('serverResourceId')]",
                "[variables('securityAlertPolicyResourceId')]",
                "[variables('advancedDataSecurityStorageBlobDataContributorRoleAssignmentResourceId')]",
                "[variables('vulnerabilityAssessmentResourceId')]"
            ],
            "location": "[parameters('location')]",
            "name": "[format('{0}/{1}', variables('serverName'), variables('databases')[copyIndex()].databaseName)]",
            "properties": {
                "autoPauseDelay": -1,
                "catalogCollation": "DATABASE_DEFAULT",
                "collation": "SQL_Latin1_General_CP1_CI_AS",
                "createMode": "Default",
                "licenseType": "BasePrice"
            },
            "sku": {
                "name": "[variables('databases')[copyIndex()].skuName]"
            },
            "type": "Microsoft.Sql/servers/databases"
        }
    ]
}
