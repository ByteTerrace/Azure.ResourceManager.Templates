{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "activeDirectoryAdministratorObjectId": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the Active Directory administrator object ID that will be assigned to the Azure SQL server."
            },
            "type": "string"
        },
        "activeDirectoryAdministratorTenantId": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the Active Directory administrator tenant ID that will be assigned to the Azure SQL server."
            },
            "type": "string"
        },
        "activeDirectoryAdministratorUserName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the Active Directory administrator user name that will be assigned to the Azure SQL server."
            },
            "type": "string"
        },
        "advancedDataSecurityDisabledAlerts": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of alert names that will be disabled within the advanced data security feature."
            },
            "type": "array"
        },
        "advancedDataSecurityEmailAddresses": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of email addresses that will be notified by the advanced data security feature."
            },
            "type": "array"
        },
        "auditActionsAndGroupNames": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of audit action and group names that will be enabled within the audit feature."
            },
            "type": "array"
        },
        "auditRetentionInDays": {
            "defaultValue": 0,
            "metadata": {
                "description": "Specifies the number of days worth of audit logs that the audit feature will retain."
            },
            "type": "int"
        },
        "auditStorageAccountName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the name of the Azure Storage account that will be utilized by the audit feature."
            },
            "type": "string"
        },
        "auditStorageAccountResourceGroupName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the resource group name of the Azure Storage account that will be utilized by the audit feature."
            },
            "type": "string"
        },
        "connectionPolicy": {
            "allowedValues": [
                "Default",
                "Proxy",
                "Redirect"
            ],
            "defaultValue": "Default",
            "metadata": {
                "description": "Specifies how clients will connect to the Azure SQL server."
            },
            "type": "string"
        },
        "databases": {
            "defaultValue": [
                {
                    "catalogCollation": "DATABASE_DEFAULT",
                    "collation": "SQL_Latin1_General_CP1_CI_AS",
                    "databaseName": "ByteTerrace-Example",
                    "isAzureHybridBenefitEnabled": false,
                    "skuName": "Basic"
                }
            ],
            "metadata": {
                "description": "An array of databases that will be created within the Azure SQL server."
            },
            "type": "array"
        },
        "dnsAliases": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of dns aliases that will be assigned to the Azure SQL server."
            },
            "type": "array"
        },
        "encryptionKeyVaultKeyName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the name of the customer-managed data encryption key."
            },
            "type": "string"
        },
        "encryptionKeyVaultKeyVersion": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the version of the customer-managed data encryption key."
            },
            "type": "string"
        },
        "encryptionKeyVaultName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the name of the key vault that houses the customer-managed data encryption key."
            },
            "type": "string"
        },
        "encryptionKeyVaultResourceGroupName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the resource group name of the key vault that houses the customer-managed data encryption key."
            },
            "type": "string"
        },
        "firewallRules": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of firewall rules that will be assigned to the Azure SQL server."
            },
            "type": "array"
        },
        "location": {
            "defaultValue": "[resourceGroup().location]",
            "metadata": {
                "description": "Specifies the location in which the Azure SQL server resource(s) will be deployed."
            },
            "type": "string"
        },
        "isAzureResourceAccessEnabled": {
            "defaultValue": false,
            "metadata": {
                "description": "Indicates whether Azure services and resources are allowed to access the Azure SQL server."
            },
            "type": "bool"
        },
        "isPublicNetworkAccessEnabled": {
            "defaultValue": false,
            "metadata": {
                "description": "Indicates whether the public network access feature is enabled on the Azure SQL server."
            },
            "type": "bool"
        },
        "serverName": {
            "metadata": {
                "description": "Specifies the name of the Azure SQL server."
            },
            "type": "string"
        },
        "serverVersion": {
            "allowedValues": [
                "12.0"
            ],
            "defaultValue": "12.0",
            "metadata": {
                "description": "Specifies the version of the Azure SQL server."
            },
            "type": "string"
        },
        "sqlAdministratorUserName": {
            "defaultValue": "[uniqueString(toLower(parameters('serverName')))]",
            "metadata": {
                "description": "Specifies the default SQL administrator user name that will be assigned to the Azure SQL server."
            },
            "type": "securestring"
        },
        "sqlAdministratorUserPassword": {
            "defaultValue": "[newGuid()]",
            "metadata": {
                "description": "Specifies the default SQL administrator user password that will be assigned to the Azure SQL server."
            },
            "type": "securestring"
        },
        "tags": {
            "defaultValue": {},
            "metadata": {
                "description": "Specifies the set of tag key-value pairs that will be assigned to the Azure SQL server."
            },
            "type": "object"
        },
        "virtualNetworkRules": {
            "defaultValue": [],
            "metadata": {
                "description": "An array of virtual network rules that will be assigned to the Azure SQL server."
            },
            "type": "array"
        },
        "vulnerabilityAssessmentStorageAccountName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the name of the Azure Storage account that will be utilized by the vulnerability assessment feature."
            },
            "type": "string"
        },
        "vulnerabilityAssessmentStorageAccountResourceGroupName": {
            "defaultValue": "",
            "metadata": {
                "description": "Specifies the resource group name of the Azure Storage account that will be utilized by the vulnerability assessment feature."
            },
            "type": "string"
        }
    },
    "variables": {
        "administratorApiVersion": "2019-06-01-preview",
        "auditApiVersion": "2017-03-01-preview",
        "auditStorageAccountName": "[if(not(empty(coalesce(parameters('auditStorageAccountName'), ''))), parameters('auditStorageAccountName'), 'DummyStorageAccountForAudit')]",
        "auditStorageAccountResourceGroupName": "[if(not(empty(coalesce(parameters('auditStorageAccountResourceGroupName'), ''))), parameters('auditStorageAccountResourceGroupName'), resourceGroup().name)]",
        "auditStorageAccountResourceId": "[resourceId(variables('auditStorageAccountResourceGroupName'), 'Microsoft.Storage/storageAccounts', parameters('auditStorageAccountName'))]",
        "auditStorageBlobDataContributorRoleAssignmentDeploymentName": "[uniqueString(variables('serverName'), 'auditStorageBlobDataContributorRoleAssignment')]",
        "auditStorageBlobDataContributorRoleAssignmentUniqueId": "[guid(variables('auditStorageAccountResourceId'), variables('storageBlobDataContributorRoleResourceId'), variables('serverResourceId'))]",
        "authorizationRoleAssignmentApiVersion": "2018-09-01-preview",
        "connectionPolicyApiVersion": "2014-04-01",
        "customerEncryptionKeyDeploymentName": "[uniqueString(variables('serverName'), 'keyVaultAccessPolicyAssignment')]",
        "customerEncryptionKeyName": "[format('{0}_{1}_{2}', variables('customerEncryptionKeyVaultName'), if(not(empty(coalesce(parameters('encryptionKeyVaultKeyName'), ''))), parameters('encryptionKeyVaultKeyName'), 'DummyKeyName'), if(not(empty(coalesce(parameters('encryptionKeyVaultKeyVersion'), ''))), parameters('encryptionKeyVaultKeyVersion'), 'DummyKeyVersion'))]",
        "customerEncryptionKeyResourceId": "[resourceId('Microsoft.Sql/servers/keys', variables('serverName'), variables('customerEncryptionKeyName'))]",
        "customerEncryptionKeyVaultName": "[if(not(empty(coalesce(parameters('encryptionKeyVaultName'), ''))), parameters('encryptionKeyVaultName'), 'DummyKeyVault')]",
        "customerEncryptionKeyVaultResourceGroupName": "[if(not(empty(coalesce(parameters('encryptionKeyVaultResourceGroupName'), ''))), parameters('encryptionKeyVaultResourceGroupName'), resourceGroup().name)]",
        "customerEncryptionKeyVaultResourceId": "[resourceId(variables('customerEncryptionKeyVaultResourceGroupName'), 'Microsoft.KeyVault/vaults/', variables('customerEncryptionKeyVaultName'))]",
        "databases": "[if(variables('databasesIsNotEmpty'), parameters('databases'), json('[ { \"databaseName\": \"DummyDatabase\", \"isAzureHybridBenefitEnabled\": false, \"skuName\": \"Basic\" } ]'))]",
        "databasesCount": "[length(parameters('databases'))]",
        "databasesIsNotEmpty": "[greater(variables('databasesCount'), 0)]",
        "databasesTemplateUri": "https://dev.azure.com/ByteTerrace/Azure/_apis/git/repositories/Azure.ResourceManager.Templates/Items?path=%2FMicrosoft.Sql%2Fdatabases%2FMicrosoft.Sql-databases.json&recursionLevel=0&versionDescriptor.version=master&versionDescriptor.versionOptions=0&versionDescriptor.versionType=0&includeContent=true&resolveLfs=true",
        "deploymentApiVersion": "2019-10-01",
        "dnsAliasApiVersion": "2017-03-01-preview",
        "dnsAliases": "[if(variables('dnsAliasesIsNotEmpty'), parameters('dnsAliases'), json('[ \"dummyDnsAlias\" ]'))]",
        "dnsAliasesCount": "[length(parameters('dnsAliases'))]",
        "dnsAliasesIsNotEmpty": "[greater(variables('dnsAliasesCount'), 0)]",
        "encryptionProtectorApiVersion": "2015-05-01-preview",
        "firewallRuleApiVersion": "2015-05-01-preview",
        "firewallRules": "[if(variables('firewallRulesIsNotEmpty'), parameters('firewallRules'), json('[ { \"endIpAddress\": \"0.0.0.0\", \"ruleName\": \"dummyFirewallRule\", \"startIpAddress\": \"0.0.0.0\" }]'))]",
        "firewallRulesCount": "[length(parameters('firewallRules'))]",
        "firewallRulesIsNotEmpty": "[greater(variables('firewallRulesCount'), 0)]",
        "isActiveDirectoryAdministratorEnabled": "[or(not(empty(coalesce(parameters('activeDirectoryAdministratorObjectId'), ''))), not(empty(coalesce(parameters('activeDirectoryAdministratorTenantId'), ''))), not(empty(coalesce(parameters('activeDirectoryAdministratorUserName'), ''))))]",
        "isAdvancedDataSecurityEnabled": "[or(greater(length(parameters('advancedDataSecurityEmailAddresses')), 0), variables('isVulnerabilityAssessmentStorageAccountEnabled'))]",
        "isAuditEnabled": "[variables('isAuditStorageAccountEnabled')]",
        "isAuditStorageAccountEnabled": "[or(not(empty(coalesce(parameters('auditStorageAccountResourceGroupName'), ''))), not(empty(coalesce(parameters('auditStorageAccountName'), ''))))]",
        "isCustomerEncryptionKeyEnabled": "[or(not(empty(coalesce(parameters('encryptionKeyVaultResourceGroupName'), ''))), not(empty(coalesce(parameters('encryptionKeyVaultName'), ''))), not(empty(coalesce(parameters('encryptionKeyVaultKeyName'), ''))))]",
        "isStorageBlobDataContributorRoleAssignmentUnique": "[not(equals(variables('vulnerabilityAssessmentStorageBlobDataContributorRoleAssignmentUniqueId'), variables('auditStorageBlobDataContributorRoleAssignmentUniqueId')))]",
        "isVulnerabilityAssessmentStorageAccountEnabled": "[or(not(empty(coalesce(parameters('vulnerabilityAssessmentStorageAccountResourceGroupName'), ''))), not(empty(coalesce(parameters('vulnerabilityAssessmentStorageAccountName'), ''))))]",
        "keyApiVersion": "2015-05-01-preview",
        "keyVaultAccessPolicyApiVersion": "2018-02-14",
        "keyVaultApiVersion": "2018-02-14",
        "securityAlertPolicyApiVersion": "2017-03-01-preview",
        "securityAlertPolicyResourceId": "[resourceId('Microsoft.Sql/servers/securityAlertPolicies', variables('serverName'), 'default')]",
        "serverApiVersion": "2019-06-01-preview",
        "serverName": "[toLower(parameters('serverName'))]",
        "serverResourceId": "[resourceId('Microsoft.Sql/servers', variables('serverName'))]",
        "storageAccountApiVersion": "2019-06-01",
        "storageBlobDataContributorRoleResourceId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'ba92f5b4-2d11-453d-a403-e96b0029c9fe')]",
        "virtualNetworkRuleApiVersion": "2015-05-01-preview",
        "virtualNetworkRules": "[if(variables('virtualNetworkRulesIsNotEmpty'), parameters('virtualNetworkRules'), json('[ { \"ignoreMissingVnetServiceEndpoint\": false, \"ruleName\": \"dummyVirtualNetworkRule\", \"subnetName\": \"dummySubnet\", \"virtualNetworkName\": \"dummyVirtualNetwork\", \"virtualNetworkResourceGroupName\": \"dummyResourceGroup\" } ]'))]",
        "virtualNetworkRulesCount": "[length(parameters('virtualNetworkRules'))]",
        "virtualNetworkRulesIsNotEmpty": "[greater(variables('virtualNetworkRulesCount'), 0)]",
        "vulnerabilityAssessmentApiVersion": "2018-06-01-preview",
        "vulnerabilityAssessmentResourceId": "[resourceId('Microsoft.Sql/servers/vulnerabilityAssessments', variables('serverName'), 'default')]",
        "vulnerabilityAssessmentStorageAccountName": "[if(not(empty(coalesce(parameters('vulnerabilityAssessmentStorageAccountName'), ''))), parameters('vulnerabilityAssessmentStorageAccountName'), 'DummyStorageAccountForAds')]",
        "vulnerabilityAssessmentStorageAccountResourceGroupName": "[if(not(empty(coalesce(parameters('vulnerabilityAssessmentStorageAccountResourceGroupName'), ''))), parameters('vulnerabilityAssessmentStorageAccountResourceGroupName'), resourceGroup().name)]",
        "vulnerabilityAssessmentStorageAccountResourceId": "[resourceId(variables('vulnerabilityAssessmentStorageAccountResourceGroupName'), 'Microsoft.Storage/storageAccounts', parameters('vulnerabilityAssessmentStorageAccountName'))]",
        "vulnerabilityAssessmentStorageBlobDataContributorRoleAssignmentDeploymentName": "[uniqueString(variables('serverName'), 'advancedDataSecurityStorageBlobDataContributorRoleAssignment')]",
        "vulnerabilityAssessmentStorageBlobDataContributorRoleAssignmentUniqueId": "[guid(variables('vulnerabilityAssessmentStorageAccountResourceId'), variables('storageBlobDataContributorRoleResourceId'), variables('serverResourceId'))]"
    },
    "resources": [
        {
            "apiVersion": "[variables('serverApiVersion')]",
            "identity": {
                "type": "SystemAssigned"
            },
            "location": "[parameters('location')]",
            "name": "[variables('serverName')]",
            "properties": {
                "administratorLogin": "[parameters('sqlAdministratorUserName')]",
                "administratorLoginPassword": "[parameters('sqlAdministratorUserPassword')]",
                "minimalTlsVersion": "1.2",
                "publicNetworkAccess": "[if(parameters('isPublicNetworkAccessEnabled'), 'Enabled', 'Disabled')]",
                "version": "[parameters('serverVersion')]"
            },
            "tags": "[parameters('tags')]",
            "type": "Microsoft.Sql/servers"
        },
        {
            "apiVersion": "[variables('connectionPolicyApiVersion')]",
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/default', variables('serverName'))]",
            "properties": {
                "connectionType": "[parameters('connectionPolicy')]"
            },
            "type": "Microsoft.Sql/servers/connectionPolicies"
        },
        {
            "apiVersion": "[variables('dnsAliasApiVersion')]",
            "condition": "[variables('dnsAliasesIsNotEmpty')]",
            "copy": {
                "count": "[variables('dnsAliasesCount')]",
                "mode": "parallel",
                "name": "dnsAliasCopy"
            },
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/{1}', variables('serverName'), toLower(variables('dnsAliases')[copyIndex()]))]",
            "type": "Microsoft.Sql/servers/dnsAliases"
        },
        {
            "apiVersion": "[variables('firewallRuleApiVersion')]",
            "condition": "[parameters('isAzureResourceAccessEnabled')]",
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/AllowAllWindowsAzureIps', variables('serverName'))]",
            "properties": {
                "endIpAddress": "0.0.0.0",
                "startIpAddress": "0.0.0.0"
            },
            "type": "Microsoft.Sql/servers/firewallRules"
        },
        {
            "apiVersion": "[variables('firewallRuleApiVersion')]",
            "condition": "[variables('firewallRulesIsNotEmpty')]",
            "copy": {
                "count": "[variables('firewallRulesCount')]",
                "mode": "parallel",
                "name": "firewallRulesCopy"
            },
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/{1}', variables('serverName'), variables('firewallRules')[copyIndex()].ruleName)]",
            "properties": {
                "endIpAddress": "[variables('firewallRules')[copyIndex()].endIpAddress]",
                "startIpAddress": "[variables('firewallRules')[copyIndex()].startIpAddress]"
            },
            "type": "Microsoft.Sql/servers/firewallRules"
        },
        {
            "apiVersion": "[variables('virtualNetworkRuleApiVersion')]",
            "condition": "[variables('virtualNetworkRulesIsNotEmpty')]",
            "copy": {
                "count": "[variables('virtualNetworkRulesCount')]",
                "mode": "parallel",
                "name": "virtualNetworkRulesCopy"
            },
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/{1}', variables('serverName'), variables('virtualNetworkRules')[copyIndex()].ruleName)]",
            "properties": {
                "ignoreMissingVnetServiceEndpoint": "[union(json('{ \"ignoreMissingVnetServiceEndpoint\": false }'), variables('virtualNetworkRules')[copyIndex()]).ignoreMissingVnetServiceEndpoint]",
                "virtualNetworkSubnetId": "[resourceId(union(json(format('{{ \"virtualNetworkResourceGroupName\": \"{0}\" }}', resourceGroup().name)), variables('virtualNetworkRules')[copyIndex()]).virtualNetworkResourceGroupName, 'Microsoft.Network/virtualNetworks/subnets', variables('virtualNetworkRules')[copyIndex()].virtualNetworkName, variables('virtualNetworkRules')[copyIndex()].subnetName)]"
            },
            "type": "Microsoft.Sql/servers/virtualNetworkRules"
        },
        {
            "apiVersion": "[variables('administratorApiVersion')]",
            "condition": "[variables('isActiveDirectoryAdministratorEnabled')]",
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/activeDirectory', variables('serverName'))]",
            "properties": {
                "administratorType": "ActiveDirectory",
                "login": "[parameters('activeDirectoryAdministratorUserName')]",
                "sid": "[parameters('activeDirectoryAdministratorObjectId')]",
                "tenantId": "[parameters('activeDirectoryAdministratorTenantId')]"
            },
            "type": "Microsoft.Sql/servers/administrators"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "condition": "[variables('isCustomerEncryptionKeyEnabled')]",
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[variables('customerEncryptionKeyDeploymentName')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {},
                "template": {
                    "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
                    "contentVersion": "1.0.0.0",
                    "resources": [
                        {
                            "apiVersion": "[variables('keyVaultAccessPolicyApiVersion')]",
                            "name": "[format('{0}/add', variables('customerEncryptionKeyVaultName'))]",
                            "properties": {
                                "accessPolicies": [
                                    {
                                        "objectId": "[reference(variables('serverResourceId'), variables('serverApiVersion'), 'Full').identity.principalId]",
                                        "permissions": {
                                            "certificates": [],
                                            "keys": [
                                                "Get",
                                                "UnwrapKey",
                                                "WrapKey"
                                            ],
                                            "secrets": []
                                        },
                                        "tenantId": "[subscription().tenantId]"
                                    }
                                ]
                            },
                            "type": "Microsoft.KeyVault/vaults/accessPolicies"
                        }
                    ]
                }
            },
            "resourceGroup": "[variables('customerEncryptionKeyVaultResourceGroupName')]",
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('keyApiVersion')]",
            "condition": "[variables('isCustomerEncryptionKeyEnabled')]",
            "dependsOn": [
                "[variables('serverResourceId')]",
                "[variables('customerEncryptionKeyDeploymentName')]"
            ],
            "kind": "AzureKeyVault",
            "name": "[format('{0}/{1}', variables('serverName'), variables('customerEncryptionKeyName'))]",
            "properties": {
                "serverKeyType": "AzureKeyVault",
                "uri": "[format('{0}keys/{1}/{2}', if(variables('isCustomerEncryptionKeyEnabled'), reference(variables('customerEncryptionKeyVaultResourceId'), variables('keyVaultApiVersion'), 'Full').properties.vaultUri, 'https://dummy.domain/'), parameters('encryptionKeyVaultKeyName'), parameters('encryptionKeyVaultKeyVersion'))]"
            },
            "type": "Microsoft.Sql/servers/keys"
        },
        {
            "apiVersion": "[variables('encryptionProtectorApiVersion')]",
            "condition": "[variables('isCustomerEncryptionKeyEnabled')]",
            "dependsOn": [
                "[variables('serverResourceId')]",
                "[variables('customerEncryptionKeyResourceId')]"
            ],
            "kind": "AzureKeyVault",
            "name": "[format('{0}/current', variables('serverName'))]",
            "properties": {
                "serverKeyName": "[variables('customerEncryptionKeyName')]",
                "serverKeyType": "AzureKeyVault"
            },
            "type": "Microsoft.Sql/servers/encryptionProtector"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "condition": "[variables('isAuditStorageAccountEnabled')]",
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[variables('auditStorageBlobDataContributorRoleAssignmentDeploymentName')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {},
                "template": {
                    "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
                    "contentVersion": "1.0.0.0",
                    "resources": [
                        {
                            "apiVersion": "[variables('authorizationRoleAssignmentApiVersion')]",
                            "name": "[format('{0}/Microsoft.Authorization/{1}', variables('auditStorageAccountName'), variables('auditStorageBlobDataContributorRoleAssignmentUniqueId'))]",
                            "properties": {
                                "principalId": "[reference(variables('serverResourceId'), variables('serverApiVersion'), 'Full').identity.principalId]",
                                "principalType": "ServicePrincipal",
                                "roleDefinitionId": "[variables('storageBlobDataContributorRoleResourceId')]",
                                "scope": "[variables('auditStorageAccountResourceId')]"
                            },
                            "type": "Microsoft.Storage/storageAccounts/providers/roleAssignments"
                        }
                    ]
                }
            },
            "resourceGroup": "[variables('auditStorageAccountResourceGroupName')]",
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('auditApiVersion')]",
            "dependsOn": [
                "[variables('serverResourceId')]",
                "[variables('auditStorageBlobDataContributorRoleAssignmentDeploymentName')]"
            ],
            "name": "[format('{0}/default', variables('serverName'))]",
            "properties": {
                "auditActionsAndGroups": "[if(greater(length(parameters('auditActionsAndGroupNames')), 0), parameters('auditActionsAndGroupNames'), json('null'))]",
                "state": "[if(variables('isAuditEnabled'), 'Enabled', 'Disabled')]",
                "storageEndpoint": "[if(variables('isAuditStorageAccountEnabled'), reference(variables('auditStorageAccountResourceId'), variables('storageAccountApiVersion'), 'Full').properties.primaryEndpoints.blob, json('null'))]"
            },
            "type": "Microsoft.Sql/servers/auditingSettings"
        },
        {
            "apiVersion": "[variables('securityAlertPolicyApiVersion')]",
            "dependsOn": [
                "[variables('serverResourceId')]"
            ],
            "name": "[format('{0}/default', variables('serverName'))]",
            "properties": {
                "disabledAlerts": "[parameters('advancedDataSecurityDisabledAlerts')]",
                "emailAccountAdmins": true,
                "emailAddresses": "[parameters('advancedDataSecurityEmailAddresses')]",
                "retentionDays": "[parameters('auditRetentionInDays')]",
                "state": "[if(variables('isAdvancedDataSecurityEnabled'), 'Enabled', 'Disabled')]"
            },
            "type": "Microsoft.Sql/servers/securityAlertPolicies"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "condition": "[and(variables('isVulnerabilityAssessmentStorageAccountEnabled'), variables('isStorageBlobDataContributorRoleAssignmentUnique'))]",
            "dependsOn": [
                "[variables('serverResourceId')]",
                "[variables('securityAlertPolicyResourceId')]"
            ],
            "name": "[variables('vulnerabilityAssessmentStorageBlobDataContributorRoleAssignmentDeploymentName')]",
            "properties": {
                "mode": "Incremental",
                "parameters": {},
                "template": {
                    "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
                    "contentVersion": "1.0.0.0",
                    "resources": [
                        {
                            "apiVersion": "[variables('authorizationRoleAssignmentApiVersion')]",
                            "name": "[format('{0}/Microsoft.Authorization/{1}', variables('vulnerabilityAssessmentStorageAccountName'), variables('vulnerabilityAssessmentStorageBlobDataContributorRoleAssignmentUniqueId'))]",
                            "properties": {
                                "principalId": "[reference(variables('serverResourceId'), variables('serverApiVersion'), 'Full').identity.principalId]",
                                "principalType": "ServicePrincipal",
                                "roleDefinitionId": "[variables('storageBlobDataContributorRoleResourceId')]",
                                "scope": "[variables('vulnerabilityAssessmentStorageAccountResourceId')]"
                            },
                            "type": "Microsoft.Storage/storageAccounts/providers/roleAssignments"
                        }
                    ]
                }
            },
            "resourceGroup": "[variables('vulnerabilityAssessmentStorageAccountResourceGroupName')]",
            "type": "Microsoft.Resources/deployments"
        },
        {
            "apiVersion": "[variables('vulnerabilityAssessmentApiVersion')]",
            "condition": "[variables('isAdvancedDataSecurityEnabled')]",
            "dependsOn": [
                "[variables('serverResourceId')]",
                "[variables('securityAlertPolicyResourceId')]",
                "[variables('auditStorageBlobDataContributorRoleAssignmentDeploymentName')]",
                "[variables('vulnerabilityAssessmentStorageBlobDataContributorRoleAssignmentDeploymentName')]"
            ],
            "name": "[format('{0}/default', variables('serverName'))]",
            "properties": {
                "recurringScans": {
                    "emails": "[parameters('advancedDataSecurityEmailAddresses')]",
                    "emailSubscriptionAdmins": true,
                    "isEnabled": "[variables('isVulnerabilityAssessmentStorageAccountEnabled')]"
                },
                "storageContainerPath": "[format('{0}vulnerability-assessment/', if(variables('isVulnerabilityAssessmentStorageAccountEnabled'), reference(variables('vulnerabilityAssessmentStorageAccountResourceId'), variables('storageAccountApiVersion'), 'Full').properties.primaryEndpoints.blob, json('null')))]"
            },
            "type": "Microsoft.Sql/servers/vulnerabilityAssessments"
        },
        {
            "apiVersion": "[variables('deploymentApiVersion')]",
            "condition": "[variables('databasesIsNotEmpty')]",
            "copy": {
                "count": "[variables('databasesCount')]",
                "mode": "parallel",
                "name": "databasesCopy"
            },
            "dependsOn": [
                "[variables('serverResourceId')]",
                "[variables('securityAlertPolicyResourceId')]",
                "[variables('auditStorageBlobDataContributorRoleAssignmentDeploymentName')]",
                "[variables('vulnerabilityAssessmentStorageBlobDataContributorRoleAssignmentDeploymentName')]",
                "[variables('vulnerabilityAssessmentResourceId')]"
            ],
            "name": "[format('{0}-DbDeploy-{1}', variables('serverName'), copyIndex())]",
            "properties": {
                "mode": "Incremental",
                "parameters": {
                    "catalogCollation": {
                        "value": "[union(json('{ \"catalogCollation\": \"DATABASE_DEFAULT\" }'), variables('databases')[copyIndex()]).catalogCollation]"
                    },
                    "databaseName": {
                        "value": "[variables('databases')[copyIndex()].databaseName]"
                    },
                    "defaultCollation": {
                        "value": "[union(json('{ \"defaultCollation\": \"SQL_Latin1_General_CP1_CI_AS\" }'), variables('databases')[copyIndex()]).defaultCollation]"
                    },
                    "isAzureHybridBenefitEnabled": {
                        "value": "[union(json('{ \"isAzureHybridBenefitEnabled\": false }'), variables('databases')[copyIndex()]).isAzureHybridBenefitEnabled]"
                    },
                    "location": {
                        "value": "[parameters('location')]"
                    },
                    "serverName": {
                        "value": "[variables('serverName')]"
                    },
                    "skuName": {
                        "value": "[union(json('{ \"skuName\": \"Basic\" }'), variables('databases')[copyIndex()]).skuName]"
                    },
                    "tags": {
                        "value": "[parameters('tags')]"
                    }
                },
                "templateLink": {
                    "contentVersion": "1.0.0.0",
                    "uri": "[variables('databasesTemplateUri')]"
                }
            },
            "type": "Microsoft.Resources/deployments"
        }
    ]
}
